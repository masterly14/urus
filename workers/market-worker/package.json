{
  "name": "@urus/market-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Worker externo del Core de Inteligencia de Mercado. Captura listings desde portales inmobiliarios y persiste en Neon.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "playwright:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "dotenv": "^17.3.1",
    "fastify": "^5.5.0",
    "playwright": "^1.58.2",
    "prisma": "^6.19.2",
    "tsx": "^4.20.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
