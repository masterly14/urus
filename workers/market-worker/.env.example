# Variables del Market Worker (Railway)
# Configurar en el dashboard de Railway. NO commitear el .env real.
# Ver docs/market-worker-deploy.md §3.

# ----------------------------------------------------------------------------
# Conectividad y autenticacion
# ----------------------------------------------------------------------------

# Puerto donde escucha el server Fastify
WORKER_PORT=8080

# Secreto compartido entre Vercel y este Worker. Debe coincidir con
# MARKET_WORKER_SHARED_SECRET en el .env de Vercel. Genera uno con:
#   openssl rand -hex 32
WORKER_SHARED_SECRET=

# Conexion a Neon (la misma que usa Vercel).
# El Worker escribe directamente a MarketRawListing (decision Fase 2).
DATABASE_URL=

# Version expuesta en /internal/health. Configurar via Railway "Deploy hook"
# con el git short SHA, o dejar `dev` en local.
WORKER_VERSION=dev

# ----------------------------------------------------------------------------
# Operacion
# ----------------------------------------------------------------------------

# Concurrencia maxima de browsers Playwright simultaneos.
MAX_CONCURRENT_BROWSERS=2

# Presupuesto operativo por crawl run.
DEFAULT_BUDGET_MS=60000
DEFAULT_BUDGET_REQUESTS=50

# Deadline blando (ms): a partir de aqui el Worker responde 202 accepted y
# sigue procesando en background hasta agotar el budget total.
DEFAULT_DEADLINE_MS=8000

# Pausa minima entre requests al portal (ms). Sumar jitter recomendado.
POLITE_DELAY_MS=2500

# ----------------------------------------------------------------------------
# Runtime
# ----------------------------------------------------------------------------

LOG_LEVEL=info
NODE_ENV=production
PLAYWRIGHT_HEADLESS=true

# ----------------------------------------------------------------------------
# Idealista (Fase 2.c — decisiones.md §11)
# ----------------------------------------------------------------------------
# Feature flag local del Worker. Cuando false (default), el server NO
# registra el extractor source_d. Cuando true, el server requiere TODAS
# las BRIGHTDATA_* del bloque siguiente; si falta alguna, log warning y
# tampoco registra el extractor (degradacion suave).
# MARKET_IDEALISTA_ENABLED=false

# ----------------------------------------------------------------------------
# Bright Data (opcional en V1 — Fotocasa + Pisos.com no lo necesitan)
# ----------------------------------------------------------------------------
# Decision Fase 0 §2.2: Fotocasa y Pisos.com son laxos y no requieren
# Bright Data en V1. Estas variables se rellenan SOLO cuando se active
# Fase 2.c (Idealista) o cuando alguno de los portales actuales empiece a
# bloquear sostenidamente. Mantener todas vacias mientras tanto.

# Premium API REST (Web Unlocker). Recomendado para Idealista Fase 2.c
# segun decisiones.md §11. Token Bearer compartido tambien con Browser API.
# BRIGHTDATA_API_TOKEN=

# Web Unlocker — primary de Idealista en Fase 2.c. Zona dedicada por
# higiene de billing. Premium domain ON, custom headers/cookies OFF.
# Validacion 06/05/2026: la zone existente `web_unlocker1` traveso DataDome
# en pruebas de calibracion. Para produccion crear `web_unlocker_market`
# dedicada con Premium Domain ON.
# BRIGHTDATA_WEB_UNLOCKER_ZONE=web_unlocker_market
# BRIGHTDATA_WEB_UNLOCKER_COUNTRY=es
# BRIGHTDATA_WEB_UNLOCKER_TIMEOUT_MS=90000

# Scraping Browser (CDP/WebSocket). Solo se usa para warm-up de cookies en
# el fallback de Idealista (residentialProxy + warm-session-cookies). NO
# usarlo como primary contra Idealista — DataDome rechaza CDP segun la
# evidencia operativa de statefox-image-cache.
# BRIGHTDATA_SCRAPING_BROWSER_URL=
# BRIGHTDATA_CDP_CONNECT_TIMEOUT_MS=120000

# Residential proxy — fallback de Idealista cuando Web Unlocker falla, y
# tambien primary candidato si Fotocasa/Pisos.com empiezan a bloquear.
# BRIGHTDATA_RESIDENTIAL_PROXY_URL=
# BRIGHTDATA_RESIDENTIAL_PROXY_USERNAME=
# BRIGHTDATA_RESIDENTIAL_PROXY_PASSWORD=
# BRIGHTDATA_RESIDENTIAL_PROXY_SESSION=urus-market-prod

# TTL y maximo de uso de cookies warmed (compartidas con Statefox).
# STATEFOX_WARM_SESSION_TTL_MS=14400000     # 4 horas
# STATEFOX_WARM_SESSION_MAX_REQUESTS=40

# ----------------------------------------------------------------------------
# Fotocasa Bright Data (mayo 2026)
# ----------------------------------------------------------------------------
# Si MARKET_FOTOCASA_USE_BRIGHTDATA=true, el server cablea
# `createWebUnlockerFetcher` para Fotocasa, **reutilizando la misma zona**
# Bright Data de Idealista (`BRIGHTDATA_WEB_UNLOCKER_ZONE`) y pasando un
# header per-request `x-unblock-expect: {"element":"body"}` que sobreescribe
# el `expect_element=.re-SharedTopbar` de la zona (selector de Idealista,
# no existe en Fotocasa).
#
# Cuando false (default), Fotocasa sigue con direct-browser local (solo
# pag.1, detail bloqueado por PerimeterX/HUMAN).
#
# REQUISITO CRÍTICO: la zona Bright Data debe tener "Manual 'expect' elements"
# habilitado en Configuration → Advanced settings. Sin ese toggle Bright Data
# devuelve HTTP 400 con `feature_not_active: Manual expect is not enabled`.
#
# Por qué Web Unlocker BASTA para Fotocasa (verificado 7/05/2026):
#   - El HTML estático que devuelve incluye `window.__INITIAL_PROPS__` con
#     `realEstateAdDetailEntityV2` (descripción, teléfono del anunciante,
#     galería completa, advertiser type) Y `initialSearch.result.realEstates[]`
#     en listing (31 anuncios/página, todos con teléfono y descripción).
#   - **No requiere** simular click "Ver teléfono" ni residential proxy ni
#     warm sessions ni scraping browser CDP.
#   - Fotocasa NO expone referencia catastral en sus detalles.
#
# Si quieres una zona DEDICADA para Fotocasa (mejor para métricas separadas
# o si la cuota de Idealista no debe compartirse): define
# BRIGHTDATA_FOTOCASA_WEB_UNLOCKER_ZONE. Si vacía, usa la zona global.
# MARKET_FOTOCASA_USE_BRIGHTDATA=false
# BRIGHTDATA_FOTOCASA_WEB_UNLOCKER_ZONE=                              # default: hereda BRIGHTDATA_WEB_UNLOCKER_ZONE
# BRIGHTDATA_FOTOCASA_WEB_UNLOCKER_COUNTRY=es                          # default: hereda BRIGHTDATA_WEB_UNLOCKER_COUNTRY o "es"
# BRIGHTDATA_FOTOCASA_WEB_UNLOCKER_TIMEOUT_MS=90000                    # default: hereda BRIGHTDATA_WEB_UNLOCKER_TIMEOUT_MS
# MARKET_FOTOCASA_EXPECT_ELEMENT=body                                  # selector que Bright Data debe esperar
# MARKET_FOTOCASA_MAX_PAGES=5
# MARKET_FOTOCASA_POLITE_DELAY_MS=4000
