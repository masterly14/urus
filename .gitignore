# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Inmovilla sesión RPA (cookies sensibles)
.inmovilla-session.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Diagnósticos y scripts temporales
scripts/_*

# Archivos HAR (capturas de red sensibles)
*.har

# Archivo de migraciones archivadas (historial local, no versionable)
/prisma/migrations_archive_*/

# Workers (artefactos de build y dependencias propias)
/workers/*/node_modules
/workers/*/dist
/workers/*/.env
/workers/*/.env.local

# Capturas crudas de HTML real para calibrar parsers (no se commitean,
# pueden contener datos personales). Los fixtures sanitizados sí se commitean
# en `__tests__/fixtures/`.
/data/captures/
