echo "🔨 Verificando build..."
npm run build
if [ $? -ne 0 ]; then
  echo "❌ El build falla. Corrige los errores antes de commitear."
  exit 1
fi

echo "🔍 Buscando secretos/credenciales..."
if git diff --cached --name-only | xargs grep -lE "sk-|password=|token=|secret=" --exclude-dir=.husky --exclude=pre-commit --exclude=commit-msg --exclude=pre-push --exclude=package-lock.json 2>/dev/null; then
  echo "❌ Posibles credenciales detectadas. Revisa antes de commitear."
  exit 1
fi

echo "✅ Pre-commit OK"


branch=$(git rev-parse --abbrev-ref HEAD)
pattern="^(feat|fix|refactor|docs|test|chore)\/[A-Z0-9]+-[a-z0-9-]+$"

if ! echo "$branch" | grep -qE "$pattern"; then
  echo "❌ Nombre de rama inválido: '$branch'"
  echo "   Formato esperado: feat/M1-descripcion-kebab-case"
  exit 1
fi

if git diff --cached --name-only | grep "\.ts$" | xargs grep -l ": any" 2>/dev/null; then
  echo "⚠️  Se detectaron tipos 'any' en TypeScript. Justifícalos con un comentario."
  exit 1
fi