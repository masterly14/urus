# Base de datos (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/urus_capital"

# --- Better Auth ---
# Secret para firmar tokens/cookies (generar: openssl rand -base64 32)
# BETTER_AUTH_SECRET=
# URL base de la aplicación
# BETTER_AUTH_URL=http://localhost:3000
# Orígenes extra permitidos (sign-out, sign-in desde otro host). Coma-separado.
# Útil con ngrok/Vercel preview si NEXT_PUBLIC_APP_URL ya apunta al túnel: suele bastar con eso.
# BETTER_AUTH_TRUSTED_ORIGINS=https://xxxx.ngrok-free.app

# --- Resend (email transaccional — invitaciones de usuario) ---
# RESEND_API_KEY=
# RESEND_FROM=noreply@urus.capital

# --- CEO Seed (bootstrap inicial — npx tsx scripts/seed-ceo.ts) ---
# CEO_SEED_EMAIL=ceo@urus.capital
# CEO_SEED_PASSWORD=

# Composio (https://app.composio.dev)
# Requiere conexiones activas: Gmail (para 2FA Inmovilla) + Google Calendar (para agenda de visitas)
# COMPOSIO_API_KEY=
# COMPOSIO_USER_ID=default (legacy — solo para 2FA Inmovilla)
# Multi-tenant: cada comercial tiene su propio userId "comercial_{comercialId}"
# gestionado via /api/composio/connect + /api/composio/callback

# OpenAI — necesaria para el agente NLU de clasificación WhatsApp (M5), extracción de código 2FA y STT (M8)
# OPENAI_API_KEY=
# Modelo usado por los agentes LangGraph (por defecto gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# Modelo de transcripción de voz (M8 Smart Closing): whisper-1 o gpt-4o-transcribe / gpt-4o-mini-transcribe
# OPENAI_STT_MODEL=whisper-1
# LangSmith — trazabilidad de grafos LangGraph (opcional, recomendado en producción)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=

# Inmovilla — API REST (clientes, propiedades, propietarios). Token en Ajustes > Opciones > Token para API Rest
# INMOVILLA_API_TOKEN=
# Opcional: timeout por petición en ms (por defecto 30000). Aumentar si hay ConnectTimeout.
# INMOVILLA_REST_TIMEOUT_MS=30000
# Backfill propietarios: pausa entre GET /propietarios (default 3500ms, respeta límite 20/min).
# OWNERS_BACKFILL_DELAY_MS=3500

# Inmovilla — credenciales para login automático (RPA legacy: demandas, estados)
# INMOVILLA_USER=
# INMOVILLA_PASSWORD=
# INMOVILLA_OFFICE_KEY=
# Opcional: JSON de sesión Playwright (cookies + tokens). Por defecto: ./.inmovilla-session.json en cwd
# INMOVILLA_SESSION_FILE=
# Ingesta demandas: tras el listado, GET ficha (fichacliente.php) si falta ref Consultada. 0=off, 1=solo sin refConsultada, 2=también sin siglas/inmovillaAgentId
# INMOVILLA_DEMAND_FICHA_ENRICH=1
# INMOVILLA_DEMAND_FICHA_CONCURRENCY=4

# Cron / QStash — token compartido para autenticar endpoints de cron
# CRON_SECRET=
#
# Schedules QStash (configurar en https://console.upstash.com/qstash):
#   POST {APP_URL}/api/cron/signature-reminders      — cron: 0 9 * * * (diario 09:00 UTC)
#   POST {APP_URL}/api/cron/dashboard-alerts         — cron: 0 9 * * 1 (lunes 09:00 UTC)
#   Header: Authorization: Bearer <CRON_SECRET>
#
# QSTASH_URL=http://localhost:8080
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=

# Statefox API REST (solo lectura)
# STATEFOX_BEARER_TOKEN=...
# Opcional: timeout por petición en ms (por defecto 30000).
# STATEFOX_REST_TIMEOUT_MS=30000
# Webhook entrante POST /api/webhoook/statefox — header `apikey` debe coincidir con este valor
# STATEFOX_SECRET_KEY=

# Cloudinary — almacenamiento de documentos, contratos y adjuntos (M8 Smart Closing, etc.)
# Dashboard: https://console.cloudinary.com — copiar cloud name, API key y API secret.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Alternativa: URL única con credenciales (si se usa, las tres variables anteriores pueden omitirse en el cliente que la soporte)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Microsite: vista previa con datos ficticios en /seleccion/demo (en dev está activa sin esto; en prod, poner true para habilitar)
# NEXT_PUBLIC_MICROSITE_MOCK=true

# URL pública de la app (enlaces en WhatsApp: /seleccion/{token}, /validar-seleccion/{validationToken})
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# SLA validación microsite (cron POST /api/cron/microsite-validation-sla): WhatsApp del jefe de zona si vence el plazo de 2h
# MICROSITE_VALIDATION_ESCALATION_TO=34612345678

# WhatsApp Cloud API (Meta) — integración directa, sin BSP
# Token de acceso permanente (Meta for Developers > App > WhatsApp > API Setup > System User Token)
# WHATSAPP_ACCESS_TOKEN=
# ID del número de teléfono (Phone Number ID en Meta Business Suite > WhatsApp > Getting Started)
# WHATSAPP_PHONE_NUMBER_ID=
# ID de la cuenta WABA (WhatsApp Business Account ID)
# WHATSAPP_BUSINESS_ID=
# Token de verificación del webhook (valor libre elegido por ti, Meta lo envía en GET al registrar el webhook)
# WHATSAPP_VERIFY_TOKEN=
# App Secret (Meta for Developers > App Settings > Basic > App Secret)
# Usado para verificar la firma HMAC-SHA256 en la cabecera X-Hub-Signature-256 de cada POST del webhook
# Opcional en desarrollo, obligatorio en producción
# WHATSAPP_APP_SECRET=
# Test M4: número al que enviar plantillas/mensajes de prueba (por defecto +573113541077)
# WHATSAPP_TEST_TO=573113541077
# Test M4: usar plantilla "hello_world" (true) o solo texto (false)
# WHATSAPP_TEST_USE_TEMPLATE=true
# Feature flag global: desactiva envíos de WhatsApp dirigidos a comerciales (lead asignado, follow-up, validación microsite, visitas, pricing, nudges)
# true (default) = activo, false/0/no = desactivado
# WHATSAPP_COMMERCIAL_NOTIFICATIONS_ENABLED=true

# Alertas del sistema — se publican en el centro de notificaciones interno (management).
# No requieren variable de entorno para canal WhatsApp.

# --- Firma Digital (In-house) ---
# FIRMA_TOKEN_SECRET=generate_a_random_64_char_hex_string
# Bypass temporal OTP en flujo de firma (true/1/si). Mantener en false en producción normal.
# FIRMA_OTP_BYPASS=false
# SIGNATURIT_SLA_DAYS=5
# SIGNATURIT_SIGN_API_TOKEN=change_me_internal_token
# SIGNATURIT_PDF_CONVERTER_URL=https://your-converter.example.com/forms/libreoffice/convert
# SIGNATURIT_PDF_CONVERTER_TIMEOUT_MS=45000

# --- Vonage SMS (OTP firma) ---
# VONAGE_API_KEY=
# VONAGE_API_SECRET=
# VONAGE_SMS_FROM=Urus

# --- Plantillas WhatsApp (idioma: mismo código que en Meta, p. ej. es o es_ES) ---
# WHATSAPP_TEMPLATE_LANGUAGE=es

# --- Plantillas WhatsApp firma digital ---
# WHATSAPP_TEMPLATE_CONTRATO_FIRMA_D1=contrato_firma_recordatorio_d1
# WHATSAPP_TEMPLATE_CONTRATO_FIRMA_D3=contrato_firma_recordatorio_d3
# WHATSAPP_TEMPLATE_CONTRATO_FIRMA_D5=contrato_firma_recordatorio_d5
# WHATSAPP_TEMPLATE_CONTRATO_FIRMA_SLA_ESCALADO=contrato_firma_sla_escalado
# WHATSAPP_TEMPLATE_CONTRATO_FIRMA_ENVIADA=contrato_firma_enviada

# --- Plantilla WhatsApp pricing (M7) ---
# WHATSAPP_TEMPLATE_PRICING_INFORME=pricing_informe_listo

# --- Plantilla WhatsApp lead asignado (M3) ---
# WHATSAPP_TEMPLATE_LEAD_ASIGNADO=lead_asignado

# --- Plantilla WhatsApp notificación de match al comprador (M5) ---
# WHATSAPP_TEMPLATE_MATCH=match

# --- Vendedor por defecto (M8 MVP) ---
# Teléfono del vendedor al que se envían notificaciones de borrador y firma
# SELLER_DEFAULT_PHONE=34601257555

# --- Post-Venta (M9) ---
# WHATSAPP_TEMPLATE_POSTVENTA_AGRADECIMIENTO=postventa_agradecimiento
# WHATSAPP_TEMPLATE_POSTVENTA_RESENA=postventa_resena
# WHATSAPP_TEMPLATE_POSTVENTA_REFERIDOS=postventa_referidos
# WHATSAPP_TEMPLATE_POSTVENTA_RECAPTACION=postventa_recaptacion
# Post-venta — M9: formulario (Flow) + cumpleaños + navidad
# WHATSAPP_TEMPLATE_POSTVENTA_FORMULARIO=postventa_survey
# WHATSAPP_TEMPLATE_POSTVENTA_CUMPLEANOS=postventa_cumpleanos
# WHATSAPP_TEMPLATE_POSTVENTA_NAVIDAD=postventa_navidad
# WHATSAPP_FLOW_POSTVENTA_SURVEY_ID=
# Zona horaria y horas locales para el pipeline anual (Europe/Madrid por defecto)
# POSTVENTA_TIMEZONE=Europe/Madrid
# POSTVENTA_BIRTHDAY_HOUR_LOCAL=12
# POSTVENTA_NAVIDAD_DAY=24
# POSTVENTA_NAVIDAD_MONTH=12
# POSTVENTA_NAVIDAD_HOUR_LOCAL=12
# Nombre de la agencia para rebranding automático de descripciones (auto-validación de microsites).
# AGENCY_NAME=Urus Capital Group
# GOOGLE_REVIEW_URL=https://g.page/r/…/review
# GOOGLE_REVIEW_URL=https://g.page/r/...

# Dashboard Comercial (M10)
# Comisión estimada para calcular facturación (0.03 = 3%). Si no se define, default 0.03.
# DASHBOARD_COMMISSION_RATE=0.03
# Umbral en horas para marcar "lead perdido por falta de seguimiento" si no hay LEAD_CONTACTADO.
# DASHBOARD_LEAD_NO_FOLLOW_UP_HOURS=24

# Alertas del dashboard comercial (M10) — cron semanal: POST /api/cron/dashboard-alerts
# Porcentaje de caída vs baseline de 4 semanas para disparar alerta de rendimiento (0.30 = 30%).
# DASHBOARD_ALERT_DROP_THRESHOLD=0.30
# Número mínimo de leads sin contactar por comercial para alerta de SLA.
# DASHBOARD_ALERT_SLA_LOST_LEAD_THRESHOLD=3
# Z-score mínimo para alerta de desviación vs media del equipo.
# DASHBOARD_ALERT_DEVIATION_ZSCORE=1.5

# --- Desarrollo Continuo (M12) ---
# WHATSAPP_TEMPLATE_DEV_EXERCISE=dev_ejercicio_diario
# DEV_PROGRAM_REFERENCE_DATE=2026-04-06

# Microsite (M6) — Mapa estático en la ficha de detalle de propiedad
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# --- Agendamiento de Visitas (M4) ---
# Máximo de rondas de negociación antes de escalar a asignación manual (default: 3)
# VISIT_MAX_ROUNDS=3
# Horas que tiene el comercial para responder a una propuesta de slots (default: 2)
# VISIT_COMMERCIAL_TTL_HOURS=2
# Horas que tiene el comprador para aceptar/rechazar un horario (default: 4)
# VISIT_BUYER_TTL_HOURS=4
# Horas que tiene el comprador para indicar su preferencia tras agotar rondas (default: 6)
# VISIT_BUYER_PREF_TTL_HOURS=6
# Días laborables hacia adelante para buscar slots de visita (default: 5)
# VISIT_LOOKAHEAD_BUSINESS_DAYS=5

# --- Plantillas WhatsApp visitas (M4) ---
# WHATSAPP_TEMPLATE_VISITA_PROPUESTA_SLOTS=visita_propuesta_slots
# WHATSAPP_TEMPLATE_VISITA_RECHAZO_COMPRADOR=visita_rechazo_comprador
# WHATSAPP_TEMPLATE_VISITA_CONFIRMAR_FECHA=visita_confirmar_fecha_comprador
# WHATSAPP_TEMPLATE_VISITA_ESCALADO_MANUAL=visita_escalado_manual
# WHATSAPP_TEMPLATE_VISITA_CONFIRMADA_COMERCIAL=visita_confirmada_comercial
# WHATSAPP_TEMPLATE_VISITA_CONFIRMADA_COMPRADOR=visita_confirmada_comprador
# WHATSAPP_TEMPLATE_VISITA_ESCALADO_COMPRADOR=visita_escalado_comprador
# WHATSAPP_TEMPLATE_VISITA_CANCELADA=visita_cancelada_comprador

# --- Nota de Encargo ---
# WHATSAPP_FLOW_NOTA_ENCARGO_ID=          # ID del Flow en Meta Business Manager
# WHATSAPP_TEMPLATE_NOTA_ENCARGO_RECORDATORIO=nota_encargo_recordatorio
# WHATSAPP_TEMPLATE_NOTA_ENCARGO_NO_CONFIRMADA=nota_encargo_no_confirmada
# WHATSAPP_TEMPLATE_NOTA_ENCARGO_FORMULARIO=nota_encargo
# Máximo de días en el futuro para agendar una visita de nota de encargo (default: 180)
# NOTA_ENCARGO_MAX_FUTURE_DAYS=180
# Días tras la visita para registrar que la referencia aún no apareció en Inmovilla (no cancela ni alerta; default: 7)
# NOTA_ENCARGO_MATCHING_DEADLINE_DAYS=7

# --- Parte de Visita ---
# WHATSAPP_FLOW_PARTE_VISITA_ID=          # ID del Flow en Meta Business Manager
# WHATSAPP_TEMPLATE_PARTE_VISITA_FORMULARIO=parte_visita_formulario

# --- Pusher Channels (notificaciones en tiempo real) ---
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=eu
# NEXT_PUBLIC_PUSHER_KEY=
# NEXT_PUBLIC_PUSHER_CLUSTER=eu

# --- Agente Conversacional (capa sobre NLU, responde al comprador por WhatsApp) ---
# Feature flag: true para activar agente conversacional, false para flujo legacy (clasificador sin respuesta)
# CONVERSATIONAL_AGENT_ENABLED=false
# Temperatura del LLM conversacional (0.0–1.0; 0.3 recomendado para tono natural sin alucinaciones)
# CONVERSATIONAL_AGENT_TEMPERATURE=0.3
# Máximo de rondas de tool calls antes de forzar respuesta final (default: 3)
# CONVERSATIONAL_AGENT_MAX_TOOL_ROUNDS=3

# Entorno (development | production)
# NODE_ENV=development

# --- Bootstrap Post-Deploy (Vercel) ---
# Activa la ejecución del bootstrap tras despliegue. Sin esto, el script es no-op.
# BOOTSTRAP_ON_DEPLOY=true
# Modo: safe (solo seed CEO + check DB) | full (seed + sync catálogos + backfills)
# BOOTSTRAP_MODE=safe

# --- Railway Session Proxy ---
# Servicio Docker que renueva la sesión CRM v2 de Inmovilla cada N segundos
# y la persiste en Neon para que los workers de Vercel la lean.

# --- Egestion: sincronización de estado Inmovilla (Tier 2 D) ---
# Cuando true, al cerrar/perder una demanda (CERRADO, PERDIDO) se escribe
# demandas-keysitu en Inmovilla vía guardar.php. Desactivado por defecto
# por riesgo de conflicto con uso manual del CRM.
# ENABLE_INMOVILLA_STATUS_SYNC=false

# --- Matching Coverage (M5 — enriquecimiento Statefox automático) ---
# Score mínimo de match interno para considerar la demanda "cubierta" (0–100, default 60).
# Demandas con bestScore < este umbral disparan búsqueda en Statefox.
# MATCHING_COVERAGE_MIN_SCORE=60
# Días de cooldown antes de regenerar otro microsite de coverage para la misma demanda (default 7).
# MATCHING_COVERAGE_COOLDOWN_DAYS=7
# Máximo de demandas evaluadas por invocación del cron diario (default 200).
# MATCHING_COVERAGE_CRON_BATCH=200
# Variables requeridas en Railway (copiar de este .env):
#   DATABASE_URL          — misma URL de Neon que usa Vercel
#   INMOVILLA_USER        — usuario CRM Inmovilla
#   INMOVILLA_PASSWORD    — contraseña CRM Inmovilla
#   INMOVILLA_OFFICE_KEY  — clave de oficina Inmovilla
#   COMPOSIO_API_KEY      — API key de Composio (para 2FA via Gmail)
#   COMPOSIO_USER_ID      — User ID Composio con conexión Gmail
#   OPENAI_API_KEY        — para el agente que extrae el código 2FA
# Opcionales:
#   SESSION_REFRESH_INTERVAL_S — segundos entre cada refresh (default: 14400 = 4h)
#   SESSION_TTL_HOURS          — horas de validez de la sesión en DB (default: 6)
