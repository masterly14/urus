# Base de datos (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/urus_capital"

# Composio (https://app.composio.dev)
# COMPOSIO_API_KEY=
# COMPOSIO_USER_ID=default

# OpenAI — necesaria para el agente NLU de clasificación WhatsApp (M5) y extracción de código 2FA
# OPENAI_API_KEY=
# Modelo usado por los agentes LangGraph (por defecto gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# LangSmith — trazabilidad de grafos LangGraph (opcional, recomendado en producción)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=

# Inmovilla — API REST (clientes, propiedades, propietarios). Token en Ajustes > Opciones > Token para API Rest
# INMOVILLA_API_TOKEN=
# Opcional: timeout por petición en ms (por defecto 30000). Aumentar si hay ConnectTimeout.
# INMOVILLA_REST_TIMEOUT_MS=30000

# Inmovilla — credenciales para login automático (RPA legacy: demandas, estados)
# INMOVILLA_USER=
# INMOVILLA_PASSWORD=
# INMOVILLA_OFFICE_KEY=

# Cron / QStash — token compartido para autenticar endpoints de cron
# CRON_SECRET=

# Statefox API REST (solo lectura)
# STATEFOX_BEARER_TOKEN=...
# Opcional: timeout por petición en ms (por defecto 30000).
# STATEFOX_REST_TIMEOUT_MS=30000

# WhatsApp Cloud API (Meta) — integración directa, sin BSP
# Token de acceso permanente (Meta for Developers > App > WhatsApp > API Setup > System User Token)
# WHATSAPP_ACCESS_TOKEN=
# ID del número de teléfono (Phone Number ID en Meta Business Suite > WhatsApp > Getting Started)
# WHATSAPP_PHONE_NUMBER_ID=
# ID de la cuenta WABA (WhatsApp Business Account ID)
# WHATSAPP_BUSINESS_ID=
# Token de verificación del webhook (valor libre elegido por ti, Meta lo envía en GET al registrar el webhook)
# WHATSAPP_VERIFY_TOKEN=
# App Secret (Meta for Developers > App Settings > Basic > App Secret)
# Usado para verificar la firma HMAC-SHA256 en la cabecera X-Hub-Signature-256 de cada POST del webhook
# Opcional en desarrollo, obligatorio en producción
# WHATSAPP_APP_SECRET=
# Test M4: número al que enviar plantillas/mensajes de prueba (por defecto +573113541077)
# WHATSAPP_TEST_TO=573113541077
# Test M4: usar plantilla "hello_world" (true) o solo texto (false)
# WHATSAPP_TEST_USE_TEMPLATE=true

# Entorno (development | production)
# NODE_ENV=development
