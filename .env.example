# Base de datos (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/urus_capital"

# --- Better Auth ---
# Secret para firmar tokens/cookies (generar: openssl rand -base64 32)
# BETTER_AUTH_SECRET=
# URL base de la aplicación
# BETTER_AUTH_URL=http://localhost:3000
# Orígenes extra permitidos (sign-out, sign-in desde otro host). Coma-separado.
# Útil con ngrok/Vercel preview si NEXT_PUBLIC_APP_URL ya apunta al túnel: suele bastar con eso.
# BETTER_AUTH_TRUSTED_ORIGINS=https://xxxx.ngrok-free.app

# --- Resend (email transaccional — invitaciones de usuario) ---
# RESEND_API_KEY=
# RESEND_FROM=noreply@urus.capital

# --- CEO Seed (bootstrap inicial — npx tsx scripts/seed-ceo.ts) ---
# CEO_SEED_EMAIL=ceo@urus.capital
# CEO_SEED_PASSWORD=

# Composio (https://app.composio.dev)
# Requiere conexiones activas: Gmail (para 2FA Inmovilla) + Google Calendar (para agenda de visitas)
# COMPOSIO_API_KEY=
# COMPOSIO_USER_ID=default (legacy — solo para 2FA Inmovilla)
# ID `ca_…` de la conexión Gmail anclada para producción. Si está definido,
# el flujo 2FA validará que esa conexión esté ACTIVE antes de invocar al LLM y
# cortará con error tipado si está EXPIRED/INITIALIZING/INACTIVE. Recomendado.
# COMPOSIO_GMAIL_CONNECTED_ACCOUNT_ID=ca_xxxxxxxxxxxx
# Multi-tenant: cada comercial tiene su propio userId "comercial_{comercialId}"
# gestionado via /api/composio/connect + /api/composio/callback

# OpenAI — necesaria para el agente NLU de clasificación WhatsApp (M5), extracción de código 2FA y STT (M8)
# OPENAI_API_KEY=
# Modelo usado por los agentes LangGraph (por defecto gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
# Modelo de transcripción de voz (M8 Smart Closing): whisper-1 o gpt-4o-transcribe / gpt-4o-mini-transcribe
# OPENAI_STT_MODEL=whisper-1
# LangSmith — trazabilidad de grafos LangGraph (opcional, recomendado en producción)
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=

# Inmovilla — API REST (clientes, propiedades, propietarios). Token en Ajustes > Opciones > Token para API Rest
# INMOVILLA_API_TOKEN=
# Opcional: timeout por petición en ms (por defecto 30000). Aumentar si hay ConnectTimeout.
# INMOVILLA_REST_TIMEOUT_MS=30000
# Backfill propietarios: pausa entre GET /propietarios (default 3500ms, respeta límite 20/min).
# OWNERS_BACKFILL_DELAY_MS=3500

# Inmovilla — credenciales para login automático (RPA legacy: demandas, estados)
# INMOVILLA_USER=
# INMOVILLA_PASSWORD=
# INMOVILLA_OFFICE_KEY=
# Opcional: JSON de sesión Playwright (cookies + tokens). Por defecto: ./.inmovilla-session.json en cwd
# INMOVILLA_SESSION_FILE=
# Ingesta demandas: tras el listado, GET ficha (fichacliente.php) si falta ref Consultada. 0=off, 1=solo sin refConsultada, 2=también sin siglas/inmovillaAgentId
# INMOVILLA_DEMAND_FICHA_ENRICH=1
# INMOVILLA_DEMAND_FICHA_CONCURRENCY=4
# Ingesta demandas: si el listado legacy no trae teléfono, intenta reconciliar
# con REST /clientes por keycli/email. Usa INMOVILLA_API_TOKEN y respeta el
# rate limit de clientes (20/min). 0=false para desactivar.
# INMOVILLA_DEMAND_PHONE_RECONCILE=1
# INMOVILLA_DEMAND_PHONE_RECONCILE_MAX=20
# INMOVILLA_DEMAND_PHONE_RECONCILE_DELAY_MS=3500

# Cron / QStash — token compartido para autenticar endpoints de cron
# CRON_SECRET=
#
# Schedules QStash (configurar en https://console.upstash.com/qstash):
#   POST {APP_URL}/api/cron/signature-reminders      — cron: 0 9 * * * (diario 09:00 UTC)
#   POST {APP_URL}/api/cron/dashboard-alerts         — cron: 0 9 * * 1 (lunes 09:00 UTC)
#   POST {APP_URL}/api/cron/whatsapp-templates-sync  — cron: 0 3 * * * (diario 03:00 UTC)
#   POST {APP_URL}/api/cron/composio-gmail-health    — cron: 0 6 * * * (diario 06:00 UTC) — health check 2FA
#   Header: Authorization: Bearer <CRON_SECRET>
#
# QSTASH_URL=http://localhost:8080
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=

# Statefox API REST (solo lectura)
# STATEFOX_BEARER_TOKEN=...
# Kill switch global de búsqueda en cartera externa (microsite + coverage).
# Controla tanto Market in-house (Idealista/Fotocasa/Pisos via Bright Data)
# como el fallback Statefox. Si está vacío o false, EVALUATE_DEMAND_COVERAGE
# y GENERATE_MICROSITE salen no-op cuando intentan buscar externo.
# Valor recomendado en producción: true (Market in-house activo).
ENABLE_EXTERNAL_PORTFOLIO_SEARCH=true
# Opcional: timeout por petición en ms (por defecto 30000).
# STATEFOX_REST_TIMEOUT_MS=30000
# Webhook entrante POST /api/webhoook/statefox — header `apikey` debe coincidir con este valor
# STATEFOX_SECRET_KEY=

# Statefox — cache propio de imágenes de comparables (Cloudinary + Playwright).
# Las URLs `pImages` que entrega Statefox son temporales y suelen llegar caducadas
# (Idealista 403). Cuando se observa un comparable con `pLink`, el sistema abre el
# anuncio del portal con Playwright, descubre las imágenes vigentes, descarga los
# bytes desde el backend y los sube a Cloudinary; pricing y microsites usan
# después esas URLs propias en lugar de las URLs del portal.
# STATEFOX_IMAGE_IMPORT_ENABLED=true
# Importa una imagen en caliente al detectar un comparable nuevo (handler pricing /
# microsite). Mantener `true` para que el informe se genere ya con foto Cloudinary
# en el primer comparable visto; los demás se completan luego con el job asíncrono.
# Latencia RUN_PRICING_ANALYSIS (Statefox /snapshot + LLM):
# PRICING_STATEFOX_MAX_PAGES=12          # máx. páginas snapshot (antes 30)
# PRICING_MANUAL_MAX_PAGES=10            # tope extra para análisis desde UI
# PRICING_SKIP_COMPARABLE_IMAGE_HYDRATE=1 # no tocar cache/import de fotos (default on)
# MARKET_PRICING_SOURCE=marketlisting    # más rápido en ciudades con seeds (p. ej. Córdoba)
# RUN_PRICING_ANALYSIS usa hydrate cacheOnly cuando PRICING_SKIP_COMPARABLE_IMAGE_HYDRATE=0.
# STATEFOX_IMAGE_IMPORT_SYNC_ON_FIRST_SEEN=true
# Máximo de comparables nuevos a importar en caliente por ejecución (resto va al
# job asíncrono). Subir con cuidado: cada uno abre Playwright contra el portal.
# STATEFOX_IMAGE_IMPORT_SYNC_MAX_COMPARABLES=5
# Máximo de imágenes guardadas por comparable (galería completa).
# STATEFOX_IMAGE_IMPORT_MAX_IMAGES=12
# Timeout duro del worker (Playwright + descarga + Cloudinary) en ms.
# STATEFOX_IMAGE_IMPORT_TIMEOUT_MS=60000
# Warm session DataDome: usa Bright Data Scraping Browser una vez para obtener
# cookies de confianza y reusarlas luego con el proxy residencial.
# STATEFOX_WARM_SESSION_ENABLED=true
# STATEFOX_WARM_SESSION_REQUIRE_CDP=true
# STATEFOX_WARM_SESSION_TTL_MS=14400000
# STATEFOX_WARM_SESSION_MAX_REQUESTS=40
# Simulación de comportamiento humano y navegación home -> anuncio en Idealista.
# STATEFOX_HUMAN_BEHAVIOR_ENABLED=true
# STATEFOX_WARMUP_NAVIGATION_ENABLED=true
# Idealista — sesión persistente (storageState JSON exportado por scrape:idealista)
# para reducir bloqueos. Recomendado en producción.
# IDEALISTA_STORAGE_STATE=./storage/idealista-state.json
# IDEALISTA_HEADLESS=true
# Pausa antes de extraer imágenes (jitter aleatorio aplicado encima).
# IDEALISTA_IMAGE_IMPORT_DELAY_MS=3000
# Proxy opcional para mitigar bloqueos por IP. Si se define, se usa para todas las
# instancias de Playwright (idealista + extractor genérico).
# IDEALISTA_PROXY_SERVER=http://user:pass@proxy.example.com:8080
# IDEALISTA_PROXY_USERNAME=
# IDEALISTA_PROXY_PASSWORD=

# Bright Data — backend antibots para Statefox image cache.
# Opción premium: Scraping Browser (CDP/WebSocket). Si está definida, Playwright usa
# `chromium.connectOverCDP(...)`; Bright Data gestiona fingerprint, residencial,
# stealth y CAPTCHA solving.
# BRIGHTDATA_SCRAPING_BROWSER_URL=wss://brd-customer-<CUSTOMER>-zone-<ZONE>:<PASSWORD>@brd.superproxy.io:9222
# BRIGHTDATA_CDP_CONNECT_TIMEOUT_MS=120000
# BRIGHTDATA_NETWORKIDLE_TIMEOUT_MS=25000
# BRIGHTDATA_CAPTCHA_DETECT_TIMEOUT_MS=20000
# BRIGHTDATA_CAPTCHA_SOLVE_ENABLED=true
# Token de Bright Data API (Bearer). Sirve tanto para Web Unlocker (POST /request)
# como para consultar las sesiones de Browser API (status, navigations, captcha,
# end_url, error.code/message). Crearlo en https://brightdata.com/cp/setting/users
# BRIGHTDATA_API_TOKEN=
# BRIGHTDATA_SESSION_INSPECT_ENABLED=true   # default: true si BRIGHTDATA_API_TOKEN está definido
#
# Bright Data Web Unlocker — recomendado para Idealista (DataDome). Una request
# REST (POST https://api.brightdata.com/request) y devuelve el HTML renderizado
# tras pasar todos los desafíos. Pago por éxito (~$1.5/1.000 requests, premium
# para idealista.com). Dashboard: https://brightdata.com/cp/zones → "Add API"
# → Web Unlocker API. Cuando hay zona + token, el extractor de Idealista usa
# este path por defecto y bypaséa Playwright/Browser API/residencial entero.
# BRIGHTDATA_WEB_UNLOCKER_ZONE=web_unlocker1
# BRIGHTDATA_WEB_UNLOCKER_ENABLED=true       # default: true si zona + token están definidos
# BRIGHTDATA_WEB_UNLOCKER_COUNTRY=es         # opcional: forzar geolocalización del proxy
# BRIGHTDATA_WEB_UNLOCKER_TIMEOUT_MS=90000   # opcional: timeout HTTP (default 90s)
# Cuando hay BRIGHTDATA_SCRAPING_BROWSER_URL, Idealista usa CDP directo (omite warm
# session/residencial). Pon a `false` para forzar el flujo híbrido warm session +
# residencial incluso teniendo CDP disponible.
# STATEFOX_IDEALISTA_DIRECT_CDP_ENABLED=true
#
# Opción proxy residencial Bright Data (HTTP). Úsala cuando Bright Data entregue un
# comando `curl --proxy brd.superproxy.io:33335 --proxy-user ...` en lugar de una URL
# `wss://...:9222`. No incluye CAPTCHA solving CDP, pero evita la IP local.
# Equivale a `curl -k`: el extractor activa ignoreHTTPSErrors con este proxy.
# BRIGHTDATA_RESIDENTIAL_PROXY_URL=http://brd.superproxy.io:33335
# BRIGHTDATA_RESIDENTIAL_PROXY_USERNAME=brd-customer-<CUSTOMER>-zone-<ZONE>
# BRIGHTDATA_RESIDENTIAL_PROXY_PASSWORD=<PASSWORD>
# Opcional: sesión sticky para mantener la misma IP durante la navegación.
# Cambiarla fuerza otro peer residencial.
# BRIGHTDATA_RESIDENTIAL_PROXY_SESSION=urus-statefox-dev

# Statefox Image Worker (Railway) — modo híbrido rápido para Pricing.
# Vercel llama al worker con una ventana síncrona corta y, si no responde a
# tiempo, encola un job idempotente para que el consumer termine de poblar la
# galería. Si no se define STATEFOX_IMAGE_WORKER_URL, Vercel ejecuta el warm
# import en proceso (modo "local").
# STATEFOX_IMAGE_WORKER_MODE=hybrid                   # local | railway | hybrid
# STATEFOX_IMAGE_WORKER_URL=https://image-worker.up.railway.app
# STATEFOX_IMAGE_WORKER_SECRET=<shared-secret>        # mismo valor que IMAGE_WORKER_SECRET en Railway
# STATEFOX_IMAGE_WORKER_SYNC_DEADLINE_MS=3000         # ventana lógica que la API espera al worker
# STATEFOX_IMAGE_WORKER_REQUEST_TIMEOUT_MS=4500       # timeout HTTP (debe ser ligeramente mayor)
#
# En el lado Railway (servicio image-worker):
# IMAGE_WORKER_SECRET=<mismo-valor-anterior>
# IMAGE_WORKER_CONCURRENCY=2
# IMAGE_WORKER_DEADLINE_MS=4500
# PORT=8080

# Cloudinary — almacenamiento de documentos, contratos y adjuntos (M8 Smart Closing, etc.)
# Dashboard: https://console.cloudinary.com — copiar cloud name, API key y API secret.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# Alternativa: URL única con credenciales (si se usa, las tres variables anteriores pueden omitirse en el cliente que la soporte)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Microsite: vista previa con datos ficticios en /seleccion/demo (en dev está activa sin esto; en prod, poner true para habilitar)
# NEXT_PUBLIC_MICROSITE_MOCK=true

# URL pública de la app (enlaces en WhatsApp: /seleccion/{token})
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# Validación manual de microsite retirada (flujo IA-first); no requiere variable de escalado.

# WhatsApp Cloud API (Meta) — integración directa, sin BSP
# Token de acceso permanente (Meta for Developers > App > WhatsApp > API Setup > System User Token)
# Para sincronizar plantillas WABA (`npm run whatsapp:templates:sync`) debe tener permisos
# `whatsapp_business_management` y acceso granular al WABA de `WHATSAPP_BUSINESS_ID`.
# WHATSAPP_ACCESS_TOKEN=
# ID del número de teléfono (Phone Number ID en Meta Business Suite > WhatsApp > Getting Started)
# WHATSAPP_PHONE_NUMBER_ID=
# ID de la cuenta WABA (WhatsApp Business Account ID)
# WHATSAPP_BUSINESS_ID=
# Token de verificación del webhook (valor libre elegido por ti, Meta lo envía en GET al registrar el webhook)
# WHATSAPP_VERIFY_TOKEN=
# App Secret (Meta for Developers > App Settings > Basic > App Secret)
# Usado para verificar la firma HMAC-SHA256 en la cabecera X-Hub-Signature-256 de cada POST del webhook
# Opcional en desarrollo, obligatorio en producción
# WHATSAPP_APP_SECRET=
# Test M4: número al que enviar plantillas/mensajes de prueba (por defecto +573113541077)
# WHATSAPP_TEST_TO=573113541077
# Escalado conversacional (fallback NLU/contexto): número mostrado al cliente para contacto directo con administración.
# WHATSAPP_ADMIN_ESCALATION_PHONE=601257555
# Test M4: usar plantilla "hello_world" (true) o solo texto (false)
# WHATSAPP_TEST_USE_TEMPLATE=true
# Feature flag global: desactiva envíos de WhatsApp dirigidos a comerciales (lead asignado, follow-up, validación microsite, visitas, pricing, nudges)
# true (default) = activo, false/0/no = desactivado
# WHATSAPP_COMMERCIAL_NOTIFICATIONS_ENABLED=true

# --- Gastos Inteligentes por WhatsApp (backend síncrono, sin cola) ---
# Lista blanca de waId autorizados (E.164 sin +), separados por coma.
# También se autoriza por lookup DB cuando el waId pertenece a un comercial con rol ceo/admin.
# EXPENSES_ALLOWED_WA_IDS=34600111222,34600999888
# waId(s) de sandbox para pruebas del flujo de gastos. Si no se define, por defecto:
# 573113541077
# EXPENSES_TEST_WA_IDS=573113541077
# Límite de intentos de corrección antes de pedir formato guiado.
# MAX_EXPENSE_CORRECTION_ATTEMPTS=3
# TTL del estado conversacional (minutos) para confirmación/corrección.
# EXPENSE_CONVERSATION_TTL_MINUTES=30
# Tamaño máximo permitido por adjunto de gasto en bytes (default 15MB).
# MAX_EXPENSE_MEDIA_BYTES=15728640
# Modelo para extracción estructurada de gasto (texto OCR/STT -> JSON).
# OPENAI_EXPENSE_MODEL=gpt-5.4-mini
# Modelo para OCR multimodal (imagen/PDF).
# OPENAI_EXPENSE_OCR_MODEL=gpt-4.1-mini
# Finanzas CEO derivadas (v1): no añade nuevas env vars; usa DATABASE_URL y
# los datos de Expense/IncomeEntry/TreasuryBalance. Ver docs/finanzas-ceo.md.

# Alertas del sistema — se publican en el centro de notificaciones interno (management).
# No requieren variable de entorno para canal WhatsApp.

# --- Firma Digital (In-house) ---
# FIRMA_TOKEN_SECRET=generate_a_random_64_char_hex_string
# Bypass temporal OTP en flujo de firma (true/1/si). Mantener en false en producción normal.
# FIRMA_OTP_BYPASS=false
# SIGNATURIT_SLA_DAYS=5
# SIGNATURIT_SIGN_API_TOKEN=change_me_internal_token
# SIGNATURIT_PDF_CONVERTER_URL=https://your-converter.example.com/forms/libreoffice/convert
# SIGNATURIT_PDF_CONVERTER_TIMEOUT_MS=45000

# --- Vonage SMS (OTP firma) ---
# VONAGE_API_KEY=
# VONAGE_API_SECRET=
# VONAGE_SMS_FROM=Urus

# --- Plantillas WhatsApp (idioma: mismo código que en Meta, p. ej. es o es_ES) ---
# WHATSAPP_TEMPLATE_LANGUAGE=es

# --- Plantillas WhatsApp firma digital ---
# WHATSAPP_TEMPLATE_CONTRATO_FIRMA_D1=contrato_firma_recordatorio_d1
# WHATSAPP_TEMPLATE_CONTRATO_FIRMA_D3=contrato_firma_recordatorio_d3
# WHATSAPP_TEMPLATE_CONTRATO_FIRMA_D5=contrato_firma_recordatorio_d5
# WHATSAPP_TEMPLATE_CONTRATO_FIRMA_SLA_ESCALADO=contrato_firma_sla_escalado
# WHATSAPP_TEMPLATE_CONTRATO_FIRMA_ENVIADA=contrato_firma_enviada

# --- Plantilla WhatsApp pricing (M7) — cuerpo: 6 variables (nombre, ref, dirección, semáforo, gap %, URL informe) ---
# WHATSAPP_TEMPLATE_PRICING_INFORME=pricing_informe_listo

# UI estudio de mercado (pestaña Mercado, baremos, zone study en informe).
# Por defecto oculto en build si no se define. El loader de análisis en curso
# (AnalysisProcessingCard) no depende de este flag.
# NEXT_PUBLIC_PRICING_MARKET_STUDY_UI=true

# --- Plantilla WhatsApp lead asignado (M3) ---
# WHATSAPP_TEMPLATE_LEAD_ASIGNADO=lead_asignado

# --- Plantilla WhatsApp notificación de match al comprador (M5) ---
# WHATSAPP_TEMPLATE_MATCH=match

# --- Plantilla WhatsApp primer contacto NLU de demanda (comprador) ---
# Cuerpo: 2 variables (nombre comprador, mensaje breve de bienvenida)
# WHATSAPP_TEMPLATE_NLU_DEMANDA_CONTACTO_INICIAL=nlu_demanda_contacto_inicial

# --- Plantilla WhatsApp follow-up de demanda post-visita (M4) ---
# Cuerpo: 4 variables (comercial, demanda, propiedad, teléfono demanda)
# WHATSAPP_TEMPLATE_FOLLOW_UP_DEMANDA=follow_up_demanda

# --- Plantilla WhatsApp escalado chat al comercial (M5) ---
# Cuerpo: 4 variables (comercial, resumen, número de contacto, info de contacto)
# WHATSAPP_TEMPLATE_CHAT_ESCALADO_COMERCIAL=chat_escalado_comercial
# Fallback operativo si la demanda no tiene comercial asignado o no tiene waId/teléfono.
# Puede ser el waId/teléfono de Miguel (sin +, formato WhatsApp Cloud API).
# WHATSAPP_CHAT_ESCALATION_MIGUEL_PHONE=34600111222

# --- Plantillas WhatsApp micrositio comprador (M6 — flujo "Me encaja") ---
# Mensaje inicial al comprador con el enlace al micrositio.
# Cuerpo: 2 variables (nombre comprador, URL de la selección)
# WHATSAPP_TEMPLATE_MICROSITE_LISTO_COMPRADOR=microsite_listo_comprador
# Acuse al comprador tras pulsar "Me encaja" en una propiedad.
# Cuerpo: 2 variables (nombre comprador, título curado de la propiedad)
# WHATSAPP_TEMPLATE_MICROSITE_PROPIEDAD_ME_ENCAJA=microsite_propiedad_me_encaja

# --- Vendedor por defecto (M8 MVP) ---
# Teléfono del vendedor al que se envían notificaciones de borrador y firma
# SELLER_DEFAULT_PHONE=34601257555

# --- Post-Venta (M9) ---
# WHATSAPP_TEMPLATE_POSTVENTA_AGRADECIMIENTO=postventa_agradecimiento
# WHATSAPP_TEMPLATE_POSTVENTA_RESENA=postventa_resena
# WHATSAPP_TEMPLATE_POSTVENTA_REFERIDOS=postventa_referidos
# WHATSAPP_TEMPLATE_POSTVENTA_RECAPTACION=postventa_recaptacion
# Post-venta — M9: formulario (Flow) + cumpleaños + navidad
# WHATSAPP_TEMPLATE_POSTVENTA_FORMULARIO=postventa_survey
# WHATSAPP_TEMPLATE_POSTVENTA_CUMPLEANOS=postventa_cumpleanos
# WHATSAPP_TEMPLATE_POSTVENTA_NAVIDAD=postventa_navidad
# WHATSAPP_FLOW_POSTVENTA_SURVEY_ID=
# Zona horaria y horas locales para el pipeline anual (Europe/Madrid por defecto)
# POSTVENTA_TIMEZONE=Europe/Madrid
# POSTVENTA_BIRTHDAY_HOUR_LOCAL=12
# POSTVENTA_NAVIDAD_DAY=24
# POSTVENTA_NAVIDAD_MONTH=12
# POSTVENTA_NAVIDAD_HOUR_LOCAL=12
# Nombre de la agencia para rebranding automático de descripciones (auto-validación de microsites).
# AGENCY_NAME=Urus Capital Group
# GOOGLE_REVIEW_URL=https://g.page/r/…/review
# GOOGLE_REVIEW_URL=https://g.page/r/...

# Dashboard Comercial (M10)
# Comisión estimada para calcular facturación (0.03 = 3%). Si no se define, default 0.03.
# DASHBOARD_COMMISSION_RATE=0.03
# Umbral en horas para marcar "lead perdido por falta de seguimiento" si no hay LEAD_CONTACTADO.
# DASHBOARD_LEAD_NO_FOLLOW_UP_HOURS=24

# Alertas del dashboard comercial (M10) — cron semanal: POST /api/cron/dashboard-alerts
# Porcentaje de caída vs baseline de 4 semanas para disparar alerta de rendimiento (0.30 = 30%).
# DASHBOARD_ALERT_DROP_THRESHOLD=0.30
# Número mínimo de leads sin contactar por comercial para alerta de SLA.
# DASHBOARD_ALERT_SLA_LOST_LEAD_THRESHOLD=3
# Z-score mínimo para alerta de desviación vs media del equipo.
# DASHBOARD_ALERT_DEVIATION_ZSCORE=1.5

# --- Desarrollo Continuo (M12) ---
# WHATSAPP_TEMPLATE_DEV_EXERCISE=dev_ejercicio_diario
# DEV_PROGRAM_REFERENCE_DATE=2026-04-06

# Microsite (M6) — Mapa estático en la ficha de detalle de propiedad
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=
# Captación (M0/M1) — Reverse-geocoding server-side de lat/lng de MarketListing
# para autocompletar Calle/Número/CP en el modal "Crear prospecto en Inmovilla".
# Se usa Google Geocoding API; resultado cacheado en kv_store por listingId.
# Si no se define, se intenta usar NEXT_PUBLIC_GOOGLE_MAPS_KEY como fallback
# (ojo: esa key suele estar restringida por referrer para uso navegador).
# Recomendado: clave dedicada server-side con restricción por IP de Vercel/Railway.
# Endpoint: GET /api/market/listings/[id]/reverse-geocode
# GOOGLE_MAPS_API_KEY=
# Centro de referencia para el script de tiempos de viaje M7+
# (lat,lng; p.ej. Córdoba centro = 37.8882,-4.7794)
# MARKET_CITY_CENTER_COORDS=37.8882,-4.7794

# --- Agendamiento de Visitas (M4) ---
# Máximo de rondas de negociación antes de escalar a asignación manual (default: 3)
# VISIT_MAX_ROUNDS=3
# Horas que tiene el comercial para responder a una propuesta de slots (default: 2)
# VISIT_COMMERCIAL_TTL_HOURS=2
# Horas que tiene el comprador para aceptar/rechazar un horario (default: 4)
# VISIT_BUYER_TTL_HOURS=4
# Horas que tiene el comprador para indicar su preferencia tras agotar rondas (default: 6)
# VISIT_BUYER_PREF_TTL_HOURS=6
# Días laborables hacia adelante para buscar slots de visita (default: 5)
# VISIT_LOOKAHEAD_BUSINESS_DAYS=5

# --- Plantillas WhatsApp visitas (M4) ---
# WHATSAPP_TEMPLATE_VISITA_PROPUESTA_SLOTS=visita_propuesta_slots
# WHATSAPP_TEMPLATE_VISITA_RECHAZO_COMPRADOR=visita_rechazo_comprador
# WHATSAPP_TEMPLATE_VISITA_CONFIRMAR_FECHA=visita_confirmar_fecha_comprador
# WHATSAPP_TEMPLATE_VISITA_ESCALADO_MANUAL=visita_escalado_manual
# WHATSAPP_TEMPLATE_VISITA_CONFIRMADA_COMERCIAL=visita_confirmada_comercial
# Paquete operativo al comercial (4 vars: demanda, tel comprador, resumen propiedades/contactos, siguiente acción)
# WHATSAPP_TEMPLATE_VISITA_PAQUETE_COMERCIAL=visita_paquete_comercial
# WHATSAPP_TEMPLATE_VISITA_CONFIRMADA_COMPRADOR=visita_confirmada_comprador
# WHATSAPP_TEMPLATE_VISITA_ESCALADO_COMPRADOR=visita_escalado_comprador
# WHATSAPP_TEMPLATE_VISITA_CANCELADA=visita_cancelada_comprador

# --- Nota de Encargo ---
# WHATSAPP_FLOW_NOTA_ENCARGO_ID=          # ID del Flow en Meta Business Manager
# WHATSAPP_TEMPLATE_NOTA_ENCARGO_FORMULARIO=nota_encargo
# Deprecadas (flujo sin confirmación del propietario — jun 2026; no referenciar en código):
# WHATSAPP_TEMPLATE_NOTA_ENCARGO_RECORDATORIO=nota_encargo_recordatorio
# WHATSAPP_TEMPLATE_NOTA_ENCARGO_NO_CONFIRMADA=nota_encargo_no_confirmada
# Máximo de días en el futuro para agendar una visita de nota de encargo (default: 180)
# NOTA_ENCARGO_MAX_FUTURE_DAYS=180
# Días tras la visita para registrar que la referencia aún no apareció en Inmovilla (no cancela ni alerta; default: 7)
# NOTA_ENCARGO_MATCHING_DEADLINE_DAYS=7
# Al crear la sesión se programan en QStash:
#   - formulario al comercial en visitDateTime → POST /api/nota-encargo/formulario
#   - matching-check N días después (si sin propiedad) → POST /api/nota-encargo/matching-check
# Los endpoints recordatorio y check-confirmacion responden deprecated_noop (callbacks legacy).
# Requiere QSTASH_TOKEN + QSTASH_CURRENT_SIGNING_KEY + QSTASH_NEXT_SIGNING_KEY y
# NEXT_PUBLIC_APP_URL apuntando al dominio público de la app.
#
# Red de seguridad: cron /api/cron/nota-encargo-rescate (cada 15 min) detecta
# NotaEncargoSession PENDING/PENDIENTE_PROPIEDAD cuya visitDateTime ya pasó y
# fuerza el envío del formulario (idempotente — claim optimista en send.ts).
# Registrar schedule: npm run nota-encargo:register-rescate-cron
# Tunables opcionales:
# NOTA_ENCARGO_RESCATE_GRACE_MIN=5
# NOTA_ENCARGO_RESCATE_LOOKBACK_MIN=10080
# NOTA_ENCARGO_RESCATE_MAX_BATCH=50
# Migración sesiones en vuelo (pre/post deploy flujo sin confirmación):
# npm run nota-encargo:migrate-drop-confirmacion -- --confirm

# --- Parte de Visita ---
# WHATSAPP_FLOW_PARTE_VISITA_ID=          # ID del Flow en Meta Business Manager
# WHATSAPP_TEMPLATE_PARTE_VISITA_FORMULARIO=parte_visita_formulario
# WHATSAPP_TEMPLATE_PARTE_VISITA_CONTEXTO=visita_contexto_propiedad
# Cada plantilla puede estar aprobada en un código de idioma distinto en Meta.
# Si no se indica, se usa WHATSAPP_TEMPLATE_LANGUAGE como fallback.
# WHATSAPP_TEMPLATE_PARTE_VISITA_FORMULARIO_LANGUAGE=es
# WHATSAPP_TEMPLATE_PARTE_VISITA_CONTEXTO_LANGUAGE=es_ES
# Por defecto el Flow se envía vía PLANTILLA con botón Flow vinculado en Meta
# (siempre entrega, no requiere ventana de 24 h). Esta env var activa la rama
# `interactive` (mensaje interactivo, requiere ventana de 24 h abierta y se
# pierde silenciosamente si no la hay). SOLO usar 1 en escenarios donde se
# garantice la ventana (pruebas internas).
# WHATSAPP_PARTE_VISITA_PREFER_INTERACTIVE=0
# El Parte de Visita se programa en QStash con notBefore = visitDateTime y se
# entrega al endpoint POST /api/parte-visita/send en el instante exacto.
# Requiere QSTASH_TOKEN + QSTASH_CURRENT_SIGNING_KEY + QSTASH_NEXT_SIGNING_KEY
# (mismas vars que el resto de crons QStash) y NEXT_PUBLIC_APP_URL apuntando
# al dominio público de la app para que Upstash pueda llamarlo.
#
# Red de seguridad: cron /api/cron/parte-visita-rescate (cada 15 min) detecta
# ParteVisitaSession PENDING cuya visitDateTime ya pasó y fuerza el envío
# (idempotente — el claim atómico en sendParteVisitaForSession evita duplicar).
# Tunables opcionales:
# PARTE_VISITA_RESCATE_GRACE_MIN=5
# PARTE_VISITA_RESCATE_LOOKBACK_MIN=10080
# PARTE_VISITA_RESCATE_MAX_BATCH=50

# --- Pusher Channels (notificaciones en tiempo real) ---
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=eu
# NEXT_PUBLIC_PUSHER_KEY=
# NEXT_PUBLIC_PUSHER_CLUSTER=eu

# --- Agente Conversacional (capa sobre NLU, responde al comprador por WhatsApp) ---
# Feature flag: true para activar agente conversacional, false para flujo legacy (clasificador sin respuesta)
# CONVERSATIONAL_AGENT_ENABLED=false
# Temperatura del LLM conversacional (0.0–1.0; 0.3 recomendado para tono natural sin alucinaciones)
# CONVERSATIONAL_AGENT_TEMPERATURE=0.3
# Máximo de rondas de tool calls antes de forzar respuesta final (default: 3)
# CONVERSATIONAL_AGENT_MAX_TOOL_ROUNDS=3

# Entorno (development | production)
# NODE_ENV=development

# --- Bootstrap Post-Deploy (Vercel) ---
# Activa la ejecución del bootstrap tras despliegue. Sin esto, el script es no-op.
# BOOTSTRAP_ON_DEPLOY=true
# Modo: safe (solo seed CEO + check DB) | full (seed + sync catálogos + backfills)
# BOOTSTRAP_MODE=safe

# --- Railway Session Proxy ---
# Servicio Docker que renueva la sesión CRM v2 de Inmovilla cada N segundos
# y la persiste en Neon para que los workers de Vercel la lean.

# --- Egestion: sincronización de estado Inmovilla (Tier 2 D) ---
# Cuando true, al cerrar/perder una demanda (CERRADO, PERDIDO) se escribe
# demandas-keysitu en Inmovilla vía guardar.php. Desactivado por defecto
# por riesgo de conflicto con uso manual del CRM.
# ENABLE_INMOVILLA_STATUS_SYNC=false

# --- Matching Coverage (M5 — enriquecimiento Statefox automático) ---
# Score mínimo de match interno para considerar la demanda "cubierta" (0–100, default 60).
# Demandas con bestScore < este umbral disparan búsqueda en Statefox.
# MATCHING_COVERAGE_MIN_SCORE=60
# Días de cooldown antes de regenerar otro microsite de coverage para la misma demanda (default 7).
# MATCHING_COVERAGE_COOLDOWN_DAYS=7
# Máximo de demandas evaluadas por invocación del cron diario (default 200).
# MATCHING_COVERAGE_CRON_BATCH=200
# Variables requeridas en Railway (copiar de este .env):
#   DATABASE_URL          — misma URL de Neon que usa Vercel
#   INMOVILLA_USER        — usuario CRM Inmovilla
#   INMOVILLA_PASSWORD    — contraseña CRM Inmovilla
#   INMOVILLA_OFFICE_KEY  — clave de oficina Inmovilla
#   COMPOSIO_API_KEY      — API key de Composio (para 2FA via Gmail)
#   COMPOSIO_USER_ID      — User ID Composio con conexión Gmail
#   OPENAI_API_KEY        — para el agente que extrae el código 2FA
# Opcionales:
#   SESSION_REFRESH_INTERVAL_S — segundos entre cada refresh (default: 14400 = 4h)
#   SESSION_TTL_HOURS          — horas de validez de la sesión en DB (default: 6)

# ---------------------------------------------------------------------------
# Core de Inteligencia de Mercado (Market*)
# Ver:
#   - docs/core-sistema-mercado.md
#   - docs/core-sistema-mercado-plan-implementacion.md
#   - docs/core-sistema-mercado-decisiones.md
#   - docs/market-worker-deploy.md (operación cotidiana §11)
# ---------------------------------------------------------------------------

# Feature flag global del Core. Si false, los crons /api/cron/market/* hacen
# no-op explícito (devuelven { skipped: true }) sin desconfigurar QStash.
# MARKET_FEATURE_ENABLED=false

# Feature flag para el pipeline comercial síncrono de captación
# (oportunidad -> prospecto -> propiedad) desde `/platform/captacion/oportunidades`.
# Cuando false, los endpoints:
#   - POST /api/market/listings/:id/inmovilla-prospect
#   - POST /api/market/listings/:id/promote-property
# devuelven 503 con code=FEATURE_DISABLED.
# MARKET_CAPTACION_SYNC_ENABLED=false

# Feature flag específico de Idealista (Fase 2.c, decisiones.md §11).
# Cuando false (default), los crons NO encolan source_d aunque haya seeds
# activos en DB; el Worker tampoco registra el extractor Idealista.
# Activar SOLO después de:
#   1. Crear la zone web_unlocker_market en Bright Data dashboard con
#      Premium Domain ON y Custom Headers/Cookies OFF.
#   2. Validar coste (~43 USD/mes) en plan operativo.
#   3. Smoke con --limit 1 sin abrir el circuit breaker.
# MARKET_IDEALISTA_ENABLED=false

# Worker externo del Core (servicio Railway dedicado, ver Fase 2 del plan).
# El backend siempre habla con el Worker vía MARKET_WORKER_BASE_URL; la UI
# nunca habla directo con el Worker.
# MARKET_WORKER_BASE_URL=https://market-worker.internal
# MARKET_WORKER_SHARED_SECRET=replace-me-with-random-32+chars
# MARKET_WORKER_REQUEST_TIMEOUT_MS=8000

# Calidad mínima publicable. Listings con qualityScore < umbral no entran en
# el snapshot público. Ver lib/market/quality.ts (DEFAULT_MIN_QUALITY_SCORE=0.4).
# MARKET_MIN_QUALITY_SCORE=0.4

# Frescura: a partir de cuántos ms un listing se considera stale_data.
# Default: 259200000 (3 días).
# MARKET_STALE_AFTER_MS=259200000

# Retención automática (cron diario `/api/cron/market/purge` a las 03:00 UTC).
# Ver decisiones.md §7 y runbook §11.7.
#   - MARKET_RAW_RETENTION_DAYS: borrar MarketRawListing > N días.
#   - MARKET_VERSIONS_RETENTION_DAYS: borrar MarketListingVersion > N días.
#   - MarketListing/MarketProperty/MarketEvent/MarketSnapshotIndex NO se
#     purgan automáticamente.
# MARKET_RAW_RETENTION_DAYS=30
# MARKET_VERSIONS_RETENTION_DAYS=365

# Schedules QStash (configurar en https://console.upstash.com/qstash con
# Authorization: Bearer ${CRON_SECRET}, ver runbook §11.2):
#   POST {APP_URL}/api/cron/market/discover-seeds   — */15 * * * *
#   POST {APP_URL}/api/cron/market/crawl-tick       — */5 * * * *
#   POST {APP_URL}/api/cron/market/refresh-snapshot — */30 * * * *
#   POST {APP_URL}/api/cron/market/health-check     — */5 * * * *
#   POST {APP_URL}/api/cron/market/run-rules        — */10 * * * * (no-op V1)
#   POST {APP_URL}/api/cron/market/purge            — 0 3 * * *

# Bright Data (compartidas con cache de imágenes; el Worker las reutiliza).
# Si ya están definidas más arriba (BRIGHTDATA_*), no es necesario duplicar.
# Pisos.com (V1 activo) NO requiere Bright Data (direct-browser sin auth).
# Idealista (Fase 2.c, decisiones.md §11) usa Web Unlocker como primary y
# residential proxy + warm-cookies como fallback (ver MARKET_IDEALISTA_ENABLED).
# Fotocasa (mayo 2026) opcionalmente usa Bright Data via MARKET_FOTOCASA_USE_BRIGHTDATA
# (ver bloque de "Worker — Fotocasa Bright Data" abajo).
# BRIGHTDATA_API_TOKEN=
# BRIGHTDATA_WEB_UNLOCKER_ZONE=web_unlocker_market
# BRIGHTDATA_WEB_UNLOCKER_COUNTRY=es
# BRIGHTDATA_WEB_UNLOCKER_TIMEOUT_MS=90000
# BRIGHTDATA_SCRAPING_BROWSER_URL=
# BRIGHTDATA_RESIDENTIAL_PROXY_URL=
# BRIGHTDATA_RESIDENTIAL_PROXY_USERNAME=
# BRIGHTDATA_RESIDENTIAL_PROXY_PASSWORD=

# Worker — Fotocasa Bright Data (opcional). Cuando MARKET_FOTOCASA_USE_BRIGHTDATA=true
# el Worker cablea `createWebUnlockerFetcher` para Fotocasa, reutilizando la MISMA
# zona Bright Data de Idealista (`web_unlocker1` por defecto) y pasando un header
# per-request `x-unblock-expect: {"element":"body"}` para sobreescribir el selector
# `expect_element=.re-SharedTopbar` que la zona tiene configurado para Idealista
# (NO existe en Fotocasa y produciría HTTP 502 sin el override).
#
# Si false (default), Fotocasa sigue con direct-browser local (solo pag.1, detail
# bloqueado por PerimeterX/HUMAN).
#
# REQUISITO CRÍTICO: la zona Bright Data debe tener "Manual 'expect' elements"
# habilitado en la configuración avanzada (Control Panel → Web Unlocker zone →
# Configuration → Advanced settings). Sin ese toggle Bright Data devuelve
# HTTP 400 con `feature_not_active: Manual expect is not enabled for this zone`.
#
# Por qué Web Unlocker basta para Fotocasa (verificado 7/05/2026 con HTML real):
#   - El HTML estático de Fotocasa expone `window.__INITIAL_PROPS__` con
#     `realEstateAdDetailEntityV2` que incluye descripción completa, teléfono
#     del anunciante (`publisher.phone`), galería completa (`multimedias[]`),
#     tipo de anunciante (`publisher.type`) y referencia interna del anuncio.
#   - **No requiere** simular click "Ver teléfono" ni residential proxy.
#   - Fotocasa NO expone referencia catastral (verificado).
#
# Si quieres una zona DEDICADA para Fotocasa (mejor para métricas separadas):
# define `BRIGHTDATA_FOTOCASA_WEB_UNLOCKER_ZONE`. Si vacía, reusa la zona global.
# MARKET_FOTOCASA_USE_BRIGHTDATA=false
# BRIGHTDATA_FOTOCASA_WEB_UNLOCKER_ZONE=                              # default: hereda BRIGHTDATA_WEB_UNLOCKER_ZONE
# BRIGHTDATA_FOTOCASA_WEB_UNLOCKER_COUNTRY=es                          # default: hereda BRIGHTDATA_WEB_UNLOCKER_COUNTRY o "es"
# BRIGHTDATA_FOTOCASA_WEB_UNLOCKER_TIMEOUT_MS=90000                    # default: hereda BRIGHTDATA_WEB_UNLOCKER_TIMEOUT_MS
# MARKET_FOTOCASA_EXPECT_ELEMENT=body                                  # selector que Bright Data debe esperar
# MARKET_FOTOCASA_MAX_PAGES=5
# MARKET_FOTOCASA_POLITE_DELAY_MS=4000

# Variables del Worker (configurar en Railway dashboard, no aquí — ver
# workers/market-worker/.env.example y runbook §3):
#   WORKER_PORT=8080
#   WORKER_SHARED_SECRET=...        # mismo valor que MARKET_WORKER_SHARED_SECRET
#   DATABASE_URL=postgres://...     # misma DB que Vercel (Neon)
#   WORKER_VERSION=<git-short-sha>
#   MAX_CONCURRENT_BROWSERS=2
#   DEFAULT_BUDGET_MS=60000
#   DEFAULT_BUDGET_REQUESTS=50
#   DEFAULT_DEADLINE_MS=8000
#   POLITE_DELAY_MS=2500
#   PLAYWRIGHT_HEADLESS=true
#   LOG_LEVEL=info
#   NODE_ENV=production
#   # Bright Data (solo cuando se active Fase 2.c — Idealista):
#   BRIGHTDATA_API_TOKEN=...
#   BRIGHTDATA_WEB_UNLOCKER_ZONE=web_unlocker_market
#   BRIGHTDATA_SCRAPING_BROWSER_URL=...
#   BRIGHTDATA_RESIDENTIAL_PROXY_URL=...
#   BRIGHTDATA_RESIDENTIAL_PROXY_USERNAME=...
#   BRIGHTDATA_RESIDENTIAL_PROXY_PASSWORD=...
#   # Fotocasa Bright Data (opcional, mayo 2026):
#   MARKET_FOTOCASA_USE_BRIGHTDATA=true
#   # Si vacía, reusa BRIGHTDATA_WEB_UNLOCKER_ZONE (la zona de Idealista). El
#   # override `x-unblock-expect: {"element":"body"}` se pasa per-request.
#   BRIGHTDATA_FOTOCASA_WEB_UNLOCKER_ZONE=
#   MARKET_FOTOCASA_EXPECT_ELEMENT=body
#   MARKET_FOTOCASA_MAX_PAGES=5
#   MARKET_FOTOCASA_POLITE_DELAY_MS=4000
#
# Market image cache policy (pricing/microsites con MarketListing):
# - Por defecto se sirven URLs directas del portal.
# - Solo se encola import lazy a Cloudinary para los portales listados aquí.
# - Default implícito en código: "idealista" (por URLs caducables/403).
# - Para añadir más portales ante fallos, usar CSV: "idealista,fotocasa".
# MARKET_IMAGE_IMPORT_PORTALS=idealista
