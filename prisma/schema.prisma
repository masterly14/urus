// ---------------------------------------------------------------------------
// Operacion formal (M11 — ancla para colaboradores, contratos, post-venta)
// ---------------------------------------------------------------------------

enum OperacionEstado {
  EN_CURSO
  OFERTA_FIRME
  RESERVA
  ARRAS
  PENDIENTE_FIRMA
  CERRADA_VENTA
  CERRADA_ALQUILER
  CERRADA_TRASPASO
  CANCELADA
}

enum ManualSyncTaskType {
  PROPERTY
  DEMAND
}

enum ManualSyncTaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  BLOCKED
}

enum ManualSyncTaskSource {
  COMERCIAL_DELETE_TRANSFER
}

model Operacion {
  id             String          @id @default(cuid())
  codigo         String          @unique
  propertyCode   String
  demandId       String?
  buyerClientId  String?
  sellerClientId String?
  comercialId    String?
  ciudad         String          @default("")
  estado         OperacionEstado @default(EN_CURSO)
  closedAt       DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  asignaciones   ColaboradorAsignacion[]
  notas          OperacionNota[]
  checklistItems OperacionChecklistItem[]
  adjuntos       OperacionAdjunto[]

  @@index([propertyCode, estado])
  @@index([comercialId, createdAt])
  @@index([ciudad, estado])
  @@index([estado, closedAt])
  @@map("operaciones")
}

// ---------------------------------------------------------------------------
// Panel lateral por operación: notas internas, checklist ad-hoc y adjuntos.
// Modelos mutables (no event store) — ver docs/plan.md M11.
// ---------------------------------------------------------------------------

/// Nota interna asociada a una operación. Visibilidad:
/// - CEO/admin: todas las notas.
/// - comercial: solo las suyas (filtradas por authorUserId en la API).
/// Nunca se incluyen en PDFs ni mensajes al cliente.
model OperacionNota {
  id           String   @id @default(cuid())
  operacionId  String
  authorUserId String
  authorName   String
  /// "ceo" | "admin" | "comercial" — congelado en el momento de creación.
  authorRole   String
  content      String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  operacion Operacion @relation(fields: [operacionId], references: [id], onDelete: Cascade)

  @@index([operacionId, createdAt])
  @@index([authorUserId])
  @@map("operacion_notas")
}

/// Ítem de checklist ad-hoc en una operación. Ordenable mediante `orden`.
/// NO avanza el stage del pipeline automáticamente — es tracking operativo.
model OperacionChecklistItem {
  id                       String    @id @default(cuid())
  operacionId              String
  texto                    String
  completado               Boolean   @default(false)
  orden                    Int       @default(0)
  responsableComercialId   String?
  responsableColaboradorId String?
  createdByUserId          String
  completadoByUserId       String?
  completadoAt             DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  operacion   Operacion    @relation(fields: [operacionId], references: [id], onDelete: Cascade)
  colaborador Colaborador? @relation(fields: [responsableColaboradorId], references: [id], onDelete: SetNull)

  @@index([operacionId, orden])
  @@index([responsableComercialId])
  @@index([responsableColaboradorId])
  @@map("operacion_checklist_items")
}

/// Adjunto subido por un usuario a una operación. Se almacena en Cloudinary
/// como resource_type=raw (PDF/Word) o image (jpg/png/webp).
model OperacionAdjunto {
  id               String   @id @default(cuid())
  operacionId      String
  nombre           String
  mimeType         String
  cloudinaryUrl    String
  publicId         String
  resourceType     String   @default("raw")
  bytes            Int
  uploadedByUserId String
  uploadedByName   String
  createdAt        DateTime @default(now())

  operacion Operacion @relation(fields: [operacionId], references: [id], onDelete: Cascade)

  @@index([operacionId, createdAt])
  @@map("operacion_adjuntos")
}

/// H27: secuencia atómica por año para generar `Operacion.codigo`
/// (OP-{YYYY}-{NNNN}) sin race conditions.
///
/// El viejo patrón `SELECT MAX(codigo) ... + 1` generaba códigos duplicados
/// bajo concurrencia (dos requests leían el mismo máximo y creaban operaciones
/// con el mismo código → violación del UNIQUE en `operaciones.codigo`).
///
/// Ahora `generarCodigoOperacion()` hace un `INSERT ... ON CONFLICT DO UPDATE
/// RETURNING lastValue` atómico sobre esta tabla.
model OperacionSequence {
  year      Int      @id
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("operacion_sequences")
}

