  scoringModelVersion Int?
  aiScoringUsed       Boolean @default(false)
  aiConfidence        Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  raw Json?

  @@index([assignedComercialId, createdAt])
  @@index([createdAt])
  @@index([ciudad])
  @@index([source])
  @@index([inmovillaDemandId])
