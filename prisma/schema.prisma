model CeoMonthlySnapshot {
  id                    String   @id @default(cuid())
  period                String   @unique // "2026-04"
  revenueEur            Float    @default(0)
  grossVolumeEur        Float    @default(0)
  operationsClosed      Int      @default(0)
  operationsActive      Int      @default(0)
  ebitdaEur             Float    @default(0)
  operatingCostEur      Float    @default(0)
  cashAvailableEur      Float    @default(0)
  fixedCostsEur         Float    @default(0)
  variableCostsEur      Float    @default(0)
  avgMarginPerOp        Float    @default(0)
  reinvestmentCapacity  Float    @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([period])
  @@map("ceo_monthly_snapshots")
}

model CeoTarget {
  id                  String   @id @default(cuid())
  year                Int
  month               Int?
  targetRevenueEur    Float    @default(0)
  targetEbitdaEur     Float    @default(0)
  maxOperatingCostEur Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([year, month])
  @@map("ceo_targets")
}

model WhatsAppBuyerSession {
  id             String    @id @default(cuid())
  waId           String    @unique
  demandId       String
  selectionId    String?
  selectionToken String?
  lastMessageAt  DateTime?
  turnCount      Int       @default(0)
  summary        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([demandId])
  @@map("whatsapp_buyer_sessions")
}
