enum OperacionEstado {
  EN_CURSO
  OFERTA_FIRME
  RESERVA
  ARRAS
  PENDIENTE_FIRMA
  CERRADA_VENTA
  CERRADA_ALQUILER
  CERRADA_TRASPASO
  CANCELADA
}

model Operacion {
  id             String          @id @default(cuid())
