}

model Comercial {
  id                    String    @id @default(cuid())
  nombre                String
  telefono              String    @default("")
  email                 String    @default("")
  ciudad                String
  especialidad          String    @default("general")
  activo                Boolean   @default(true)
  cargaActual           Int       @default(0)
  cargaMaxima           Int       @default(20)
  leadsAsignados        Int       @default(0)
  leadsCerrados         Int       @default(0)
  tasaConversion        Float     @default(0)
  /// WhatsApp ID del comercial (E.164 sin +, ej: "34612345678")
  waId                  String?
  /// Composio userId para la conexión OAuth de Google Calendar
  composioConnectionId  String?
  /// Fecha en que el comercial autorizó su calendario via Composio
  composioConnectedAt   DateTime?
  /// Proveedor de calendario conectado (google | outlook)
  calendarProvider      String?   @default("google")
  /// ID numérico del agente en Inmovilla (campo `keyagente` de la ficha de propiedad)
  inmovillaAgentId      Int?      @unique
  /// Iniciales del comercial en las refs de Inmovilla (ej. "MA" → URUS111VMA). Patrón: URUS{num}{V|A}{refCode}
  inmovillaRefCode      String?
  /// Si true, los microsites de este comercial se validan automáticamente con IA
  /// (descripciones generadas + rebranding) y se envían al comprador sin validación manual.
  autoValidateMicrosite Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  referrals   Referral[]
  user        User?
  invitations Invitation[]
  assignedMarketListings MarketListing[] @relation("MarketListingAssignedComercial")

  @@index([ciudad, activo])
  @@index([activo, cargaActual])
  @@index([waId])
  @@map("comerciales")
