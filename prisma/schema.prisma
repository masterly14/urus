// ---------------------------------------------------------------------------
// Core de Inteligencia de Mercado (Market*)
//
// Capa de datos del Core descrito en docs/core-sistema-mercado.md y
// docs/core-sistema-mercado-plan-implementacion.md. Construye un inventario
// canónico de mercado a partir de fuentes externas, con identidad estable,
// versionado de cambios y snapshots de lectura. Independiente del Event Store
// principal: usa MarketEvent como event log dedicado del dominio.
// ---------------------------------------------------------------------------

enum MarketSource {
  source_a
  source_b
  source_c
  source_d
  unknown
}

enum MarketOperation {
  sale
  rent
}

enum MarketHousingType {
  flat
  house
  countryhouse
  duplex
  penthouse
  studio
  loft
  garage
  office
  premises
  land
  building
  storage
  warehouse
  room
}

enum MarketListingStatus {
  active
  inactive
  removed
  blocked
  unknown
}

enum MarketCaptacionStage {
  NEW
  PROSPECT_CREATING
  PROSPECT_CREATED
  ENCARGO_ATTACHED
  READY_FOR_PROPERTY
  PROPERTY_CREATING
  PROPERTY_CREATED
  FAILED
}

enum CrawlRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  PARTIAL
}

enum RawListingStatus {
  CAPTURED
  NORMALIZED
  REJECTED
  STALE
}

enum MarketEventType {
  MARKET_LISTING_CREATED
  MARKET_LISTING_UPDATED
  MARKET_LISTING_PRICE_CHANGED
  MARKET_LISTING_STATUS_CHANGED
  MARKET_LISTING_REMOVED
  MARKET_LISTING_REAPPEARED
  MARKET_PROPERTY_MERGED
  MARKET_PROPERTY_SPLIT
  MARKET_PROPERTY_REVIEW_REQUIRED
  MARKET_SNAPSHOT_REFRESHED
}

enum MarketCircuitBreakerStatus {
  CLOSED
  OPEN
  HALF_OPEN
}

/// Semilla de rastreo: combinación (source, operation, city[, zone]) con URL de
/// listado del portal y cadencia de revisita. El scheduler selecciona seeds
/// vencidos (lastRunAt + cadenceMinutes < now) para encolar MarketCrawlRun.
model MarketSeed {
  id             String          @id @default(cuid())
  source         MarketSource
  operation      MarketOperation
  city           String
  zone           String?
  url            String
  active         Boolean         @default(true)
  priority       Int             @default(100)
  cadenceMinutes Int             @default(120)
  lastRunAt      DateTime?
  lastCursor     String?
  notes          String          @default("")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  crawlRuns MarketCrawlRun[]

  @@unique([source, operation, city, zone, url])
  @@index([active, lastRunAt])
  @@index([source, active])
  @@map("market_seeds")
}

/// Ciclo de captura para un seed concreto. Un MarketCrawlRun procesa N páginas
/// con presupuesto de tiempo/requests y materializa MarketRawListing.
model MarketCrawlRun {
  id             String         @id @default(cuid())
  seedId         String
  source         MarketSource
  status         CrawlRunStatus @default(PENDING)
  startedAt      DateTime       @default(now())
  finishedAt     DateTime?
  pagesScanned   Int            @default(0)
  itemsCaptured  Int            @default(0)
  itemsRejected  Int            @default(0)
  blockedCount   Int            @default(0)
  errorCode      String?
  errorMessage   String?
  budgetMs       Int            @default(60000)
  budgetRequests Int            @default(50)
  cursorIn       String?
  cursorOut      String?
  correlationId  String

  seed     MarketSeed         @relation(fields: [seedId], references: [id], onDelete: Cascade)
  rawItems MarketRawListing[]

  @@index([seedId, startedAt])
  @@index([status, startedAt])
  @@index([correlationId])
  @@map("market_crawl_runs")
}

/// Captura bruta indexada por contenido. La fuente de verdad técnica para
/// reproceso: si cambian las reglas de normalización, se reprocesa desde aquí
/// sin volver a raspar el portal. Retención configurable (ver decisiones.md).
model MarketRawListing {
  id              String           @id @default(cuid())
  source          MarketSource
  externalId      String?
  canonicalUrl    String
  crawlRunId      String
  httpStatus      Int?
  contentHash     String
  payload         Json
  status          RawListingStatus @default(CAPTURED)
  rejectionReason String?
  capturedAt      DateTime         @default(now())

  crawlRun MarketCrawlRun @relation(fields: [crawlRunId], references: [id], onDelete: Cascade)

  @@unique([source, contentHash])
  @@index([crawlRunId])
  @@index([source, externalId])
  @@index([status, capturedAt])
  @@map("market_raw_listings")
}

/// Listing canónico (proyección normalizada de un anuncio en un portal).
/// Identidad estable por (source, externalId). Puede vincularse a una
/// MarketProperty cuando la resolución cross-portal supera el umbral.
model MarketListing {
  id           String              @id @default(cuid())
  source       MarketSource
  externalId   String
  canonicalUrl String
  operation    MarketOperation
  housingType  MarketHousingType
  status       MarketListingStatus @default(active)

  price         Float?
  currency      String @default("EUR")
  pricePerMeter Float?

  builtArea Float?
  rooms     Int?
  bathrooms Int?
  floor     String?

  city          String
  zone          String?
  addressApprox String?
  lat           Float?
  lng           Float?
  geohash       String?

  advertiserType String?
  advertiserName String?
  phones         String[] @default([])
  advertiserId   String?
  assignedComercialId String?
  assignedAt          DateTime?
  assignedByUserId    String?

  mainImageUrl String?
  imageUrls    String[] @default([])

  description       String?
  listingReference  String?
  cadastralRef      String?
  detailFetchedAt   DateTime?
  detailFetchAttempts Int @default(0)

  qualityScore Float    @default(0)
  qualityFlags String[] @default([])

  captacionStage            MarketCaptacionStage @default(NEW)
  inmovillaProspectRef      String?
  inmovillaPropertyCodOfer  Int?
  captacionLastError        String?
  captacionUpdatedAt        DateTime             @default(now())

  propertyId   String?
  firstSeenAt  DateTime  @default(now())
  lastSeenAt   DateTime  @default(now())
  lastChangeAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property   MarketProperty?      @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  advertiser MarketAdvertiser?    @relation(fields: [advertiserId], references: [id], onDelete: SetNull)
  assignedComercial Comercial?    @relation("MarketListingAssignedComercial", fields: [assignedComercialId], references: [id], onDelete: SetNull)
  assignedByUser  User?           @relation("MarketListingAssignedByUser", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  versions   MarketListingVersion[]

  @@unique([source, externalId])
  @@index([city, zone])
  @@index([operation, housingType])
  @@index([status, lastSeenAt])
  @@index([price])
  @@index([propertyId])
  @@index([advertiserId])
  @@index([captacionStage, lastSeenAt])
  @@index([inmovillaProspectRef])
  @@index([inmovillaPropertyCodOfer])
  @@index([assignedComercialId, lastSeenAt])
  @@index([assignedByUserId])
  @@index([geohash])
  @@index([listingReference])
  @@index([cadastralRef])
  @@map("market_listings")
}

model MarketAdvertiser {
  id                 String   @id @default(cuid())
  phoneCanonical     String?
  displayName        String?
  advertiserType     String?
  inmovillaContactId String?
  listingsCount      Int      @default(0)
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  listings MarketListing[]

  @@index([advertiserType, lastSeenAt])
  @@index([displayName])
  @@map("market_advertisers")
}

/// Histórico de cambios por listing. Una fila por cambio detectado por el
/// diff engine. Retención por política (ver decisiones.md, sección 7.3).
model MarketListingVersion {
  id            String   @id @default(cuid())
  listingId     String
  changedFields String[]
  before        Json
  after         Json
  capturedAt    DateTime @default(now())

  listing MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, capturedAt])
  @@map("market_listing_versions")
}

/// Inmueble subyacente probable. Agrupa MarketListing del mismo bien físico
/// publicado en múltiples portales. La resolución se hace por fingerprint
/// determinístico + similitud (ver lib/market/identity.ts).
model MarketProperty {
  id                      String   @id @default(cuid())
  city                    String
  zone                    String?
  geohash                 String?
  fingerprint             String   @unique
  representativeListingId String?
  listingsCount           Int      @default(0)
  firstSeenAt             DateTime @default(now())
  lastSeenAt              DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  listings MarketListing[]

  @@index([city, zone])
  @@index([geohash])
  @@map("market_properties")
}

/// Event log dedicado del Core. Independiente del Event Store principal para
/// no inflarlo con el alto volumen de eventos de mercado. La idempotencia se
/// garantiza con (type, fingerprint) único por evento.
model MarketEvent {
  id            String          @id @default(cuid())
  type          MarketEventType
  listingId     String?
  propertyId    String?
  source        MarketSource?
  payload       Json
  fingerprint   String
  correlationId String
  occurredAt    DateTime        @default(now())

  @@unique([type, fingerprint])
  @@index([type, occurredAt])
  @@index([listingId, occurredAt])
  @@index([propertyId, occurredAt])
  @@index([correlationId])
  @@map("market_events")
}

/// Vista agregada por (city, housingType, operation) para consumidores
/// (búsqueda, pricing, captación). Recalculada periódicamente por
/// MARKET_REFRESH_SNAPSHOT.
model MarketSnapshotIndex {
  id          String            @id @default(cuid())
  city        String
  housingType MarketHousingType
  operation   MarketOperation
  freshAt     DateTime          @default(now())
  totalActive Int               @default(0)
  priceMin    Float?
  priceMax    Float?
  priceMedian Float?
  ppmMedian   Float?

  @@unique([city, housingType, operation])
  @@index([freshAt])
  @@map("market_snapshot_index")
}

/// Estado del circuit breaker por fuente. Se abre cuando hay tasa alta de
/// bloqueos/errores y degrada la chain anti-bot a modo conservador.
model MarketCircuitBreaker {
  source       MarketSource               @id
  status       MarketCircuitBreakerStatus @default(CLOSED)
  failureCount Int                        @default(0)
  openedAt     DateTime?
  halfOpenAt   DateTime?
  closedAt     DateTime?
  updatedAt    DateTime                   @updatedAt

  @@map("market_circuit_breakers")
}
