generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AggregateType {
  PROPERTY
  LEAD
  DEMAND
  MATCH
  SLA
  SYSTEM
  WHATSAPP_CONVERSATION
  OPERACION
  CEO
}

enum EventType {
  PROPIEDAD_CREADA
  PROPIEDAD_MODIFICADA
  ESTADO_CAMBIADO
  PROPIEDAD_ELIMINADA
  DEMANDA_CREADA
  DEMANDA_MODIFICADA
  DEMANDA_ESTADO_CAMBIADO
  LEAD_INGESTADO
  LEAD_SCORED
  LEAD_CONTACTADO
  SLA_INICIADO
  DEMANDA_ACTUALIZADA
  MATCH_GENERADO
  WHATSAPP_RECIBIDO
  WHATSAPP_ENVIADO
  VISITA_EVALUADA
  VISITA_AGENDADA
  SELECCION_COMPRADOR
  SELECCION_VALIDADA
  SELECCION_RECHAZADA
  DATOS_INCOMPLETOS
  CONTRATO_BORRADOR_GENERADO
  CONTRATO_VERSIONADO
  CONTRATO_APROBADO
  FIRMA_ENVIADA
  FIRMA_COMPLETADA
  FIRMA_RECHAZADA
  FIRMA_EXPIRADA
  FIRMA_RECORDATORIO_ENVIADO
  FIRMA_SLA_ESCALADO
  PRICING_ANALISIS_GENERADO
  PRICING_RECOMENDACION_GENERADA
  INCIDENCIA_POSTVENTA_ABIERTA
  INCIDENCIA_POSTVENTA_RESUELTA
  OPERACION_CERRADA
  RESENA_SOLICITADA
  RESENA_RECIBIDA
  RECORDATORIO_RESENA_ENVIADO
  REFERIDO_CAPTURADO
  REFERIDO_ASIGNADO
  REFERIDO_SOLICITUD_ENVIADA
  COLABORADOR_SLA_BREACH
  COLABORADOR_RECOMENDACION_GENERADA
  CEO_DIAGNOSTICO_GENERADO
  CEO_EXPANSION_EVALUADA
  CEO_FINANZAS_GENERADA
}

enum JobType {
  PROCESS_EVENT
  UPDATE_PROPERTY_PROJECTION
  UPDATE_DEMAND_PROJECTION
  WRITE_TO_INMOVILLA
  NOTIFY_LEAD_WHATSAPP
  FOLLOW_UP_LEAD
  GENERATE_MICROSITE
  NOTIFY_MICROSITE_PENDING_VALIDATION
  SEND_MICROSITE_TO_BUYER
  NOTIFY_CONTRACT_DATA_INCOMPLETE
  GENERATE_CONTRACT_DRAFT
  SEND_SIGNATURE_REQUEST
  PROCESS_SIGNATURE_WEBHOOK
  NOTIFY_SIGNATURE_REMINDER
  RUN_PRICING_ANALYSIS
  NOTIFY_PRICING_WHATSAPP
  START_POSTVENTA_CADENCE
  SEND_POSTVENTA_MESSAGE
  SEND_POST_SALE_MESSAGE
  SEND_REVIEW_REQUEST
  SEND_REFERRAL_REQUEST
  SEND_REVIEW_REMINDER
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum ProjectionName {
  PROPERTIES_CURRENT
  DEMANDS_CURRENT
}

enum SignatureRequestStatus {
  SENT
  OPENED
  SIGNED
  COMPLETED
  DECLINED
  EXPIRED
  CANCELED
  ERROR
}

enum MicrositeSelectionStatus {
  PENDING_VALIDATION
  APPROVED
  REJECTED
  EXPIRED
}

enum MicrositeSelectionDecision {
  ME_INTERESA
  NO_ME_ENCAJA
}


model Event {
  id            String        @id @default(cuid())
  position      BigInt        @unique @default(autoincrement())
  type          EventType
  aggregateType AggregateType
  aggregateId   String
  version       Int?
  payload       Json
  metadata      Json?
  correlationId String?
  causationId   String?
  occurredAt    DateTime      @default(now())
  createdAt     DateTime      @default(now())
  jobs          JobQueue[]

  @@index([aggregateType, aggregateId, position])
  @@index([type, position])
  @@index([occurredAt])
  @@map("events")
}

model JobQueue {
  id             String    @id @default(cuid())
  type           JobType
  status         JobStatus @default(PENDING)
  payload        Json
  priority       Int       @default(100)
  attempts       Int       @default(0)
  maxAttempts    Int       @default(5)
  availableAt    DateTime  @default(now())
  lockedAt       DateTime?
  lockedBy       String?
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  lastError      String?
  idempotencyKey String?   @unique
  sourceEventId  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sourceEvent    Event?    @relation(fields: [sourceEventId], references: [id])

  @@index([status, availableAt, priority])
  @@index([type, status])
  @@index([sourceEventId])
  @@map("job_queue")
}

model ProjectionCheckpoint {
  projectionName    ProjectionName @id
  lastEventId       String?
  lastEventPosition BigInt?
  lastProcessedAt   DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("projections_checkpoint")
}

model PropertySnapshot {
  codigo             String   @id
  ref                String
  titulo             String   @default("")
  tipoOfer           String   @default("")
  precio             Float    @default(0)
  metrosConstruidos  Float    @default(0)
  habitaciones       Int      @default(0)
  banyos             Int      @default(0)
  ciudad             String   @default("")
  zona               String   @default("")
  estado             String   @default("")
  nodisponible       Boolean  @default(false)
  prospecto          Boolean  @default(false)
  fechaAlta          String   @default("")
  fechaActualizacion String   @default("")
  numFotos           Int      @default(0)
  agente             String   @default("")
  raw                Json     @default("{}")
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("property_snapshots")
}

model DemandSnapshot {
  codigo             String   @id
  ref                String   @default("")
  nombre             String   @default("")
  estadoId           String   @default("")
  estadoNombre       String   @default("")
  presupuestoMin     Float    @default(0)
  presupuestoMax     Float    @default(0)
  habitacionesMin    Int      @default(0)
  tipos              String   @default("")
  zonas              String   @default("")
  fechaActualizacion String   @default("")
  agente             String   @default("")
  raw                Json     @default("{}")
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("demand_snapshots")
}

model PropertyCurrent {
  codigo             String   @id
  ref                String   @default("")
  titulo             String   @default("")
  tipoOfer           String   @default("")
  precio             Float    @default(0)
  metrosConstruidos  Float    @default(0)
  habitaciones       Int      @default(0)
  banyos             Int      @default(0)
  ciudad             String   @default("")
  zona               String   @default("")
  estado             String   @default("")
  nodisponible       Boolean  @default(false)
  prospecto          Boolean  @default(false)
  fechaAlta          String   @default("")
  fechaActualizacion String   @default("")
  numFotos           Int      @default(0)
  agente             String   @default("")
  lastEventId        String
  lastEventPosition  BigInt
  lastEventAt        DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([estado])
  @@index([ciudad, zona])
  @@index([lastEventPosition])
  @@map("properties_current")
}

model DemandCurrent {
  codigo             String   @id
  ref                String   @default("")
  nombre             String   @default("")
  estadoId           String   @default("")
  estadoNombre       String   @default("")
  presupuestoMin     Float    @default(0)
  presupuestoMax     Float    @default(0)
  habitacionesMin    Int      @default(0)
  tipos              String   @default("")
  zonas              String   @default("")
  fechaActualizacion String   @default("")
  agente             String   @default("")
  lastEventId        String
  lastEventPosition  BigInt
  lastEventAt        DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  /// * Teléfono del contacto/comprador si la ingesta lo expone (E.164 o dígitos).
  telefono           String   @default("")

  @@index([estadoId])
  @@index([zonas])
  @@index([lastEventPosition])
  @@map("demands_current")
}

model IngestionCycleMetric {
  id                String   @id @default(cuid())
  cycleId           String   @unique
  worker            String
  mode              String
  success           Boolean
  startedAt         DateTime
  finishedAt        DateTime
  durationMs        Int
  itemsRead         Int      @default(0)
  itemsFetched      Int      @default(0)
  itemsFailed       Int      @default(0)
  snapshotSize      Int      @default(0)
  eventsEmitted     Int      @default(0)
  diffCreated       Int      @default(0)
  diffModified      Int      @default(0)
  diffStatusChanged Int      @default(0)
  diffUnchanged     Int      @default(0)
  errorMessage      String?
  errorCode         String?
  phases            Json     @default("{}")
  createdAt         DateTime @default(now())

  @@index([worker, startedAt])
  @@index([success, startedAt])
  @@map("ingestion_cycle_metrics")
}

model User {
  id String @id @default(cuid())
}

model Comercial {
  id             String   @id @default(cuid())
  nombre         String
  telefono       String   @default("")
  email          String   @default("")
  ciudad         String
  especialidad   String   @default("general")
  activo         Boolean  @default(true)
  cargaActual    Int      @default(0)
  cargaMaxima    Int      @default(20)
  leadsAsignados Int      @default(0)
  leadsCerrados  Int      @default(0)
  tasaConversion Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  referrals      Referral[]

  @@index([ciudad, activo])
  @@index([activo, cargaActual])
  @@map("comerciales")
}

model InmovillaEnumCalidad {
  id        String   @id @default(cuid())
  campo     String   @unique
  valores   String
  updatedAt DateTime @updatedAt

  @@map("inmovilla_enum_calidad")
}

model InmovillaEnumTipo {
  id        String   @id @default(cuid())
  tipo      String
  nombre    String
  valor     Int
  updatedAt DateTime @updatedAt

  @@index([tipo, valor])
  @@map("inmovilla_enum_tipo")
}

model InmovillaEnumPais {
  id        String   @id @default(cuid())
  pais      String
  valor     String   @unique
  iso2      String
  iso3      String
  updatedAt DateTime @updatedAt

  @@map("inmovilla_enum_pais")
}

model InmovillaEnumCiudad {
  id         String   @id @default(cuid())
  key_loca   Int      @unique
  ciudad     String
  provincia  String
  cod_prov   Int
  pais_valor String?
  updatedAt  DateTime @updatedAt

  @@index([key_loca])
  @@index([ciudad, provincia])
  @@map("inmovilla_enum_ciudad")
}

model InmovillaEnumZona {
  id        String   @id @default(cuid())
  key_zona  Int
  key_loca  Int
  zona      String
  updatedAt DateTime @updatedAt

  @@unique([key_loca, key_zona])
  @@index([key_loca, key_zona])
  @@map("inmovilla_enum_zona")
}

model MicrositeSelection {
  id                     String                       @id @default(cuid())
  /// * Token público para el comprador: /seleccion/{token}
  token                  String                       @unique
  status                 MicrositeSelectionStatus     @default(PENDING_VALIDATION)
  demandId               String
  demandNombre           String                       @default("")
  comercialId            String                       @default("system")
  /// * Query params enviados a Statefox (/properties).
  statefoxQuery          Json
  /// * Filtros aplicados en memoria (precio/metros/keywords...).
  resultFilters          Json
  /// * Lista curada para renderizar el microsite.
  properties             Json
  stockCount             Int                          @default(0)
  sourceEventId          String?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  expiresAt              DateTime?
  firstViewedAt          DateTime?
  lastViewedAt           DateTime?
  viewCount              Int                          @default(0)
  /// * Token opaco para el comercial: /validar-seleccion/{validationToken}
  validationToken        String                       @unique
  /// * Teléfono del comprador resuelto al crear la selección (envío WA).
  buyerPhone             String                       @default("")
  /// * SLA validación comercial: deadline = createdAt + 2h (M6).
  validationDueAt        DateTime?
  validatedAt            DateTime?
  validatedByComercialId String?
  escalatedAt            DateTime?
  feedbacks              MicrositeSelectionFeedback[]

  @@index([demandId, createdAt])
  @@index([token])
  @@index([status, validationDueAt])
  @@map("microsite_selections")
}

model MicrositeSelectionFeedback {
  id          String                     @id @default(cuid())
  selectionId String
  propertyId  String
  decision    MicrositeSelectionDecision
  payload     Json?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  selection   MicrositeSelection         @relation(fields: [selectionId], references: [id], onDelete: Cascade)

  @@unique([selectionId, propertyId])
  @@index([selectionId, createdAt])
  @@map("microsite_selection_feedback")
}

// --- Legal Documents (proyección materializada del ciclo contractual) ---

enum LegalDocumentStatus {
  DRAFT
  APPROVED
  SENT_TO_SIGNATURE
  SIGNED
  DECLINED
  EXPIRED
  CANCELED
}

model LegalDocument {
  id                  String              @id @default(cuid())
  operationId         String
  propertyCode        String
  documentKind        String
  templateVersion     String?
  status              LegalDocumentStatus @default(DRAFT)
  contractInput       Json?
  cloudinaryUrl       String?
  signedDocumentUrl   String?
  auditTrailUrl       String?
  approvedAt          DateTime?
  approvedByUserId    String?
  completedAt         DateTime?
  signatureRequestId  String?             @unique
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  signatureRequest    SignatureRequest?   @relation(fields: [signatureRequestId], references: [id], onDelete: SetNull)
  parties             LegalDocumentParty[]

  @@unique([operationId, documentKind])
  @@index([propertyCode])
  @@index([status])
  @@map("legal_documents")
}

model LegalDocumentParty {
  id                String        @id @default(cuid())
  legalDocumentId   String
  role              String
  fullName          String
  nifNie            String?
  email             String?
  phone             String?
  address           String?
  inmovilla_cod_cli String?
  hasSigned         Boolean       @default(false)
  signedAt          DateTime?
  reminderDay       Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  legalDocument     LegalDocument @relation(fields: [legalDocumentId], references: [id], onDelete: Cascade)

  @@unique([legalDocumentId, email])
  @@index([legalDocumentId, hasSigned])
  @@map("legal_document_parties")
}

model SignatureRequest {
  id                     String                 @id @default(cuid())
  signaturitSignatureId  String                 @unique
  signaturitDocumentId   String?
  operationId            String
  propertyCode           String
  documentKind           String
  templateVersion        String?
  cloudinaryUrl          String
  signingUrl             String?
  status                 SignatureRequestStatus  @default(SENT)
  signerName             String
  signerEmail            String
  signerPhone            String?
  sentAt                 DateTime               @default(now())
  openedAt               DateTime?
  signedAt               DateTime?
  completedAt            DateTime?
  declinedAt             DateTime?
  expiredAt              DateTime?
  slaDeadlineDays        Int                    @default(5)
  slaDeadline            DateTime
  lastReminderDay        Int                    @default(0)
  escalatedAt            DateTime?
  signedDocumentUrl      String?
  auditTrailUrl          String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  legalDocument          LegalDocument?

  @@index([status, slaDeadline])
  @@index([operationId])
  @@map("signature_requests")
}

// ---------------------------------------------------------------------------
// Referidos (M9)
// ---------------------------------------------------------------------------

enum ReferralStatus {
  PENDIENTE_ASIGNACION
  ASIGNADO
  CONTACTADO
  DESCARTADO
}

model Referral {
  id            String         @id @default(cuid())
  propertyCode  String
  referrerName  String
  referrerPhone String
  referredName  String
  referredPhone String
  referredEmail String         @default("")
  notes         String         @default("")
  status        ReferralStatus @default(PENDIENTE_ASIGNACION)
  comercialId   String?
  comercial     Comercial?     @relation(fields: [comercialId], references: [id])
  assignedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([propertyCode])
  @@index([comercialId])
  @@map("referrals")
}

// ---------------------------------------------------------------------------
// Analytics / Dashboard Comercial (M10)
// ---------------------------------------------------------------------------

model CommercialLeadFact {
  leadId String @id

  ingestedEventId String? @unique

  tipo   String @default("")
  ciudad String @default("")
  source String @default("")

  score    Int?
  slaLevel String?

  assignedComercialId     String?
  assignedComercialNombre String?

  contactedAt            DateTime?
  contactedEventId       String?
  contactedByComercialId String?
  contactChannel         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  raw Json?

  @@index([assignedComercialId, createdAt])
  @@index([createdAt])
  @@index([ciudad])
  @@index([source])
  @@map("commercial_lead_facts")
}

model CommercialVisitFact {
  id            String @id @default(cuid())
  sourceEventId String @unique

  demandId String

  comercialId     String?
  comercialNombre String @default("")

  fecha      String @default("")
  horaInicio String @default("")
  horaFin    String @default("")
  scheduledAt DateTime?

  ubicacion String @default("")
  notas     String @default("")

  calendarEventId  String?
  calendarLink     String?
  calendarSuccess  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([comercialId, scheduledAt])
  @@index([demandId, createdAt])
  @@index([scheduledAt])
  @@map("commercial_visit_facts")
}

model CommercialVisitEvaluationFact {
  id            String @id @default(cuid())
  sourceEventId String @unique

  demandId String

  comercialId     String?
  comercialNombre String @default("")

  interes String @default("")
  notas   String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([comercialId, createdAt])
  @@index([demandId, createdAt])
  @@index([interes, createdAt])
  @@map("commercial_visit_evaluation_facts")
}

model CommercialOperationFact {
  id            String  @id @default(cuid())
  sourceEventId String  @unique

  operacionId  String?
  propertyCode String
  propertyRef  String  @default("")

  ciudad String @default("")
  zona   String @default("")

  newEstado String @default("")
  closedAt  DateTime

  firstSeenAt DateTime?
  daysToClose Int?

  grossAmountEur Float?

  comercialId     String?
  comercialNombre String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([comercialId, closedAt])
  @@index([ciudad, closedAt])
  @@index([propertyCode])
  @@index([closedAt])
  @@index([operacionId])
  @@map("commercial_operation_facts")
}

model CommercialClassification {
  id              String   @id @default(cuid())
  comercialId     String
  rangeFrom       DateTime
  rangeTo         DateTime
  profile         String
  confidence      Float    @default(0)
  profileScores   Json
  metricsSnapshot Json
  createdAt       DateTime @default(now())

  @@index([comercialId, createdAt])
  @@index([rangeFrom, rangeTo])
  @@map("commercial_classifications")
}

model DashboardAlert {
  id              String    @id @default(cuid())
  comercialId     String
  comercialNombre String    @default("")
  type            String
  severity        String
  metric          String
  message         String
  currentValue    Float?
  baselineValue   Float?
  threshold       Float?
  details         Json      @default("{}")
  notifiedAt      DateTime?
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([comercialId, createdAt])
  @@index([type, severity])
  @@index([resolvedAt, createdAt])
  @@map("dashboard_alerts")
}

// ---------------------------------------------------------------------------
// Operacion formal (M11 — ancla para colaboradores, contratos, post-venta)
// ---------------------------------------------------------------------------

enum OperacionEstado {
  EN_CURSO
  RESERVA
  ARRAS
  PENDIENTE_FIRMA
  CERRADA_VENTA
  CERRADA_ALQUILER
  CERRADA_TRASPASO
  CANCELADA
}

model Operacion {
  id             String          @id @default(cuid())
  codigo         String          @unique
  propertyCode   String
  demandId       String?
  buyerClientId  String?
  sellerClientId String?
  comercialId    String?
  ciudad         String          @default("")
  estado         OperacionEstado @default(EN_CURSO)
  closedAt       DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  asignaciones ColaboradorAsignacion[]

  @@index([propertyCode, estado])
  @@index([comercialId, createdAt])
  @@index([ciudad, estado])
  @@index([estado, closedAt])
  @@map("operaciones")
}

// ---------------------------------------------------------------------------
// Colaboradores Externos (M11)
// ---------------------------------------------------------------------------

model Colaborador {
  id               String   @id @default(cuid())
  nombre           String
  tipo             String
  ciudad           String   @default("")
  especialidad     String   @default("")
  contactoNombre   String   @default("")
  contactoEmail    String   @default("")
  contactoTelefono String   @default("")
  activo           Boolean  @default(true)
  notas            String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  asignaciones       ColaboradorAsignacion[]
  configuracionesSla ColaboradorSlaConfig[]

  @@index([tipo, ciudad, activo])
  @@index([activo])
  @@map("colaboradores")
}

model ColaboradorTipo {
  id          String   @id @default(cuid())
  nombre      String   @unique
  descripcion String   @default("")
  activo      Boolean  @default(true)
  orden       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  hitos HitoPlantilla[]

  @@map("colaborador_tipos")
}

model HitoPlantilla {
  id                String   @id @default(cuid())
  colaboradorTipoId String
  nombre            String
  orden             Int
  descripcion       String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  colaboradorTipo ColaboradorTipo @relation(fields: [colaboradorTipoId], references: [id], onDelete: Cascade)

  @@unique([colaboradorTipoId, orden])
  @@index([colaboradorTipoId])
  @@map("hito_plantillas")
}

model ColaboradorSlaConfig {
  id              String   @id @default(cuid())
  colaboradorId   String
  hitoPlantillaId String?
  slaDias         Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  colaborador Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)

  @@unique([colaboradorId, hitoPlantillaId])
  @@map("colaborador_sla_configs")
}

// ---------------------------------------------------------------------------
// Asignaciones y tracking de hitos (M11)
// ---------------------------------------------------------------------------

enum AsignacionEstado {
  PENDIENTE
  EN_PROGRESO
  COMPLETADA
  BLOQUEADA
  CANCELADA
}

enum HitoEstado {
  PENDIENTE
  EN_PROGRESO
  COMPLETADO
  BLOQUEADO
  CANCELADO
}

model ColaboradorAsignacion {
  id            String           @id @default(cuid())
  colaboradorId String
  operacionId   String
  estado        AsignacionEstado @default(PENDIENTE)
  notas         String           @default("")
  assignedAt    DateTime         @default(now())
  completedAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  colaborador Colaborador @relation(fields: [colaboradorId], references: [id])
  operacion   Operacion   @relation(fields: [operacionId], references: [id])
  hitos       ColaboradorHito[]
  documentos  DocumentoColaborador[]

  @@unique([colaboradorId, operacionId])
  @@index([operacionId, estado])
  @@index([colaboradorId, estado])
  @@map("colaborador_asignaciones")
}

model ColaboradorHito {
  id              String     @id @default(cuid())
  asignacionId    String
  hitoPlantillaId String?
  nombre          String
  orden           Int
  estado          HitoEstado @default(PENDIENTE)
  iniciadoAt      DateTime?
  completadoAt    DateTime?
  slaDias         Int?
  slaVenceAt      DateTime?
  notas           String     @default("")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  asignacion ColaboradorAsignacion @relation(fields: [asignacionId], references: [id], onDelete: Cascade)
  documentos DocumentoColaborador[]

  @@index([asignacionId, orden])
  @@index([estado, slaVenceAt])
  @@map("colaborador_hitos")
}

model DocumentoColaborador {
  id            String   @id @default(cuid())
  asignacionId  String
  hitoId        String?
  nombre        String
  cloudinaryUrl String
  publicId      String
  formato       String
  bytes         Int
  uploadedBy    String   @default("")
  createdAt     DateTime @default(now())

  asignacion ColaboradorAsignacion @relation(fields: [asignacionId], references: [id], onDelete: Cascade)
  hito       ColaboradorHito?      @relation(fields: [hitoId], references: [id], onDelete: SetNull)

  @@index([asignacionId])
  @@index([hitoId])
  @@map("documentos_colaborador")
}

