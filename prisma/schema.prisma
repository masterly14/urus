// ---------------------------------------------------------------------------
// Visit Scheduling (M4 — rediseño)
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Lead Status — pipeline interno (no depende de Inmovilla)
// ---------------------------------------------------------------------------

enum LeadStatus {
  NUEVO // Demanda recibida de Inmovilla; sin contacto aún
  CONTACTADO // Primer contacto realizado vía WhatsApp
  EN_SELECCION // Comprador interactuando con microsites o propiedades
  VISITA_PENDIENTE // Comprador expresó ME_INTERESA; coordinando visita
  VISITA_CONFIRMADA // Visita agendada en calendario (comprador aceptó slot)
  VISITA_REALIZADA // Visita completada; datos recopilados
  EN_NEGOCIACION // Post-visita: contrato o propuesta en proceso
  EN_FIRMA // Firma digital enviada / en trámite
  CERRADO // Operación cerrada exitosamente
  PERDIDO // Lead perdido (escalado sin resolución / cancelado)
}

enum VisitSessionState {
  INITIATED
  FETCHING_SLOTS
  SLOTS_PROPOSED_TO_COMMERCIAL
  COMMERCIAL_ACCEPTED_SLOT
  SLOT_PROPOSED_TO_BUYER
  BUYER_ACCEPTED
  BUYER_REJECTED
  ASKING_BUYER_PREFERENCE
  FETCHING_SPECIFIC_SLOT
  SPECIFIC_SLOT_TO_COMMERCIAL
  COLLECTING_VISITOR_DATA
  VISIT_CONFIRMED
  VISIT_COMPLETED
  VISIT_CANCELLED
  VISIT_RESCHEDULED
  ESCALATED_MANUAL
}

enum VisitWorkItemStatus {
  INCOMPLETE
  PENDING_SCHEDULE
  SCHEDULED
  COMPLETED
  DECIDED_GREEN
  DECIDED_YELLOW
  DECIDED_RED
  CANCELLED
}

enum DraftDemandStatus {
  OPEN
  PROMOTING
  PROMOTED
  CANCELLED
}

enum DraftPropertyStatus {
  OPEN
  PROMOTING
  PROMOTED
  CANCELLED
}

model DraftDemand {
  id                  String            @id @default(cuid())
  buyerPhone          String
  buyerName           String?
  comercialId         String
  demandPropertyTypes String            @default("2799")
  budgetMax           Int               @default(9999999)
  status              DraftDemandStatus @default(OPEN)
  inmovillaClientId   String?
  inmovillaDemandId   String?
  promotedAt          DateTime?
  promotionAttempts   Int               @default(0)
  lastPromotionError  String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([inmovillaDemandId])
  @@index([buyerPhone])
  @@index([comercialId, status])
  @@map("draft_demands")
}

model DraftProperty {
  id                    String              @id @default(cuid())
  ownerPhone            String
  cadastralRef          String
  comercialId           String
  keyTipo               Int?
  keyLoca               Int?
  operationType         String              @default("VENTA")
  status                DraftPropertyStatus @default(OPEN)
  inmovillaPropertyCode String?
  propertyRef           String?
  promotedAt            DateTime?
  promotionAttempts     Int                 @default(0)
  lastPromotionError    String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@unique([inmovillaPropertyCode])
  @@index([cadastralRef])
  @@index([ownerPhone])
  @@index([comercialId, status])
  @@map("draft_properties")
}

model VisitSchedulingSession {
  id                  String            @id @default(cuid())
  demandId            String            @default("")
  propertyCode        String
  draftDemandId       String?
  draftPropertyId     String?
  comercialId         String
  buyerWaId           String
  comercialWaId       String
  state               VisitSessionState @default(INITIATED)
  currentRound        Int               @default(0)
  maxRounds           Int               @default(3)
  confirmedSlotStart  DateTime?
  confirmedSlotEnd    DateTime?
  visitorName         String?
  visitorPhone        String?
  visitorCount        Int?
  calendarEventId     String?
  calendarLink        String?
  escalationReason    String?
  lastProposedSlots   Json?
  lastCommercialMsgId String?
  lastBuyerMsgId      String?
  buyerPreferredDate  String?
  currentStepDeadline DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  completedAt         DateTime?

  @@index([demandId])
  @@index([buyerWaId, state])
  @@index([comercialWaId, state])
  @@index([propertyCode, state])
  @@index([draftDemandId])
  @@index([draftPropertyId])
  @@map("visit_scheduling_sessions")
}

model VisitWorkItem {
  id                  String              @id @default(cuid())
  demandId            String              @default("")
  selectionId         String              @default("")
  propertyId          String              @default("")
  draftDemandId       String?
  draftPropertyId     String?
  propertySource      String
  comercialId         String
  buyerName           String              @default("")
  buyerPhone          String              @default("")
  propertySnapshot    Json
  contactSnapshot     Json
  nluSummary          String              @default("")
  status              VisitWorkItemStatus @default(PENDING_SCHEDULE)
  scheduledSessionId  String?
  missingContactPhone Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([demandId, draftDemandId, selectionId, propertyId, draftPropertyId])
  @@index([comercialId, status])
  @@index([demandId])
  @@index([draftDemandId])
  @@index([draftPropertyId])
  @@index([selectionId])
  @@index([propertyId])
  @@map("visit_work_items")
}

model VisitSlotLock {
  id           String   @id @default(cuid())
  comercialId  String
  propertyCode String?
  slotStart    DateTime
  slotEnd      DateTime
  sessionId    String
  expiresAt    DateTime
  released     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@unique([comercialId, slotStart, slotEnd, released])
  @@index([comercialId, expiresAt])
  @@index([propertyCode, slotStart, slotEnd])
  @@index([sessionId])
  @@map("visit_slot_locks")
}

model PropertyVisitSlot {
  id           String   @id @default(cuid())
  propertyCode String
  slotStart    DateTime
  slotEnd      DateTime
  sessionId    String
  comercialId  String
  cancelled    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([propertyCode, slotStart])
  @@index([sessionId])
  @@map("property_visit_slots")
}

// ---------------------------------------------------------------------------
// Auth (Better Auth)
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("comercial")
  /// Plugin admin (better-auth)
  banned        Boolean   @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions               Session[]
  accounts               Account[]
  comercial              Comercial?         @relation(fields: [comercialId], references: [id])
  comercialId            String?            @unique
  contractTemplates      ContractTemplate[]
  assignedMarketListings MarketListing[]    @relation("MarketListingAssignedByUser")
  prospectSentMarketListings MarketListing[] @relation("MarketListingProspectSentByUser")
  incomeEntriesCreated   IncomeEntry[]      @relation("IncomeEntryCreatedBy")
  treasuryBalances       TreasuryBalance[]  @relation("TreasuryBalanceUpdatedBy")
  coachChatSessions      CoachChatSession[]

  @@map("user")
}

model Session {
  id             String   @id @default(cuid())
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  /// Plugin admin (better-auth) — sesión de impersonación
  impersonatedBy String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

model Invitation {
  id           String     @id @default(cuid())
  email        String
  role         String
  token        String     @unique
  expiresAt    DateTime
  used         Boolean    @default(false)
  invitedBy    String
  createdAt    DateTime   @default(now())
  /// Nombre que el CEO/admin asigna al invitado; se usa al aceptar (sin pedirlo de nuevo en el registro).
  invitedName  String     @default("")
  /// Teléfono normalizado (E.164 sin +, ej. 34612345678). Obligatorio para comercial; opcional para admin.
  invitedPhone String     @default("")
  /// Ficha Comercial a vincular al aceptar (rol comercial). Evita depender de Comercial.email, que suele ir vacío.
  comercialId  String?
  comercial    Comercial? @relation(fields: [comercialId], references: [id], onDelete: SetNull)
  /// Iniciales del comercial en la ref de Inmovilla (ej. "MA", "FEDE"). Se copia a Comercial.inmovillaRefCode al aceptar.
  refCode      String?

  @@index([comercialId])
  @@map("invitation")
}

model Comercial {
  id                   String    @id @default(cuid())
  nombre               String
  telefono             String    @default("")
  email                String    @default("")
  ciudad               String
  especialidad         String    @default("general")
  activo               Boolean   @default(true)
  cargaActual          Int       @default(0)
  cargaMaxima          Int       @default(20)
  leadsAsignados       Int       @default(0)
  leadsCerrados        Int       @default(0)
  tasaConversion       Float     @default(0)
  /// WhatsApp ID del comercial (E.164 sin +, ej: "34612345678")
  waId                 String?
  /// Composio userId para la conexión OAuth de Google Calendar
  composioConnectionId String?
  /// Fecha en que el comercial autorizó su calendario via Composio
  composioConnectedAt  DateTime?
  /// Proveedor de calendario conectado (google | outlook)
  calendarProvider     String?   @default("google")
  /// ID numérico del agente en Inmovilla (campo `keyagente` de la ficha de propiedad)
  inmovillaAgentId     Int?      @unique
  /// Iniciales del comercial en las refs de Inmovilla (ej. "MA" → URUS111VMA). Patrón: URUS{num}{V|A}{refCode}
  inmovillaRefCode     String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  referrals              Referral[]
  user                   User?
  invitations            Invitation[]
  assignedMarketListings MarketListing[] @relation("MarketListingAssignedComercial")
  coachChatSessions      CoachChatSession[]

  @@index([ciudad, activo])
  @@index([activo, cargaActual])
  @@index([waId])
  @@map("comerciales")
}

model ManualSyncTask {
  id                     String               @id @default(cuid())
  type                   ManualSyncTaskType
  recordCode             String
  recordRef              String?
  targetComercialId      String
  targetComercialName    String
  targetInmovillaAgentId Int?
  status                 ManualSyncTaskStatus @default(PENDING)
  createdByUserId        String
  doneByUserId           String?
  doneAt                 DateTime?
  note                   String               @default("")
  source                 ManualSyncTaskSource
  sourceUserId           String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@unique([type, recordCode, targetComercialId, sourceUserId, source])
  @@index([status])
  @@index([targetComercialId])
  @@index([createdAt])
  @@index([sourceUserId])
  @@map("manual_sync_tasks")
}

model InmovillaEnumCalidad {
  id        String   @id @default(cuid())
  campo     String   @unique
  valores   String
  updatedAt DateTime @updatedAt

  @@map("inmovilla_enum_calidad")
}

model InmovillaEnumTipo {
  id        String   @id @default(cuid())
  tipo      String
  nombre    String
  valor     Int
  updatedAt DateTime @updatedAt

  @@index([tipo, valor])
  @@map("inmovilla_enum_tipo")
}

model InmovillaEnumPais {
  id        String   @id @default(cuid())
  pais      String
  valor     String   @unique
  iso2      String
  iso3      String
  updatedAt DateTime @updatedAt

  @@map("inmovilla_enum_pais")
}

model InmovillaEnumCiudad {
  id         String   @id @default(cuid())
  key_loca   Int      @unique
  ciudad     String
  provincia  String
  cod_prov   Int
  pais_valor String?
  updatedAt  DateTime @updatedAt

  @@index([key_loca])
  @@index([ciudad, provincia])
  @@map("inmovilla_enum_ciudad")
}

model InmovillaEnumZona {
  id        String   @id @default(cuid())
  key_zona  Int
  key_loca  Int
  zona      String
  updatedAt DateTime @updatedAt

  @@unique([key_loca, key_zona])
  @@index([key_loca, key_zona])
  @@map("inmovilla_enum_zona")
}

model MicrositeSelection {
  id            String                       @id @default(cuid())
  /// * Token público para el comprador: /seleccion/{token}
  token         String                       @unique
  status        MicrositeSelectionStatus     @default(PENDING_VALIDATION)
  demandId      String
  demandNombre  String                       @default("")
  comercialId   String                       @default("system")
  /// * Query params enviados a Statefox (/properties).
  statefoxQuery Json
  /// * Filtros aplicados en memoria (precio/metros/keywords...).
  resultFilters Json
  /// * Lista curada para renderizar el microsite.
  properties    Json
  stockCount    Int                          @default(0)
  sourceEventId String?
  createdAt     DateTime                     @default(now())
  updatedAt     DateTime                     @updatedAt
  expiresAt     DateTime?
  firstViewedAt DateTime?
  lastViewedAt  DateTime?
  viewCount     Int                          @default(0)
  /// * Teléfono del comprador resuelto al crear la selección (envío WA).
  buyerPhone    String                       @default("")
  feedbacks     MicrositeSelectionFeedback[]
  /// * Origen de la selección: "coverage_scan" | "visita_evaluada" | "feedback_loop" | null (legacy).
  source        String?

  @@index([demandId, createdAt])
  @@index([token])
  @@index([demandId, source, createdAt])
  @@map("microsite_selections")
}

model MicrositeSelectionFeedback {
  id          String                     @id @default(cuid())
  selectionId String
  propertyId  String
  decision    MicrositeSelectionDecision
  payload     Json?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  selection   MicrositeSelection         @relation(fields: [selectionId], references: [id], onDelete: Cascade)

  @@unique([selectionId, propertyId])
  @@index([selectionId, createdAt])
  @@map("microsite_selection_feedback")
}

// --- Contract Templates (plantillas editables por el equipo interno) ---

model ContractTemplate {
  id                    String    @id @default(cuid())
  documentKind          String
  version               String
  name                  String
  isActive              Boolean   @default(false)
  structure             Json
  variableBindings      Json      @default("[]")
  sharedClauseOverrides Json      @default("{}")
  createdByUserId       String?
  publishedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  createdByUser User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([documentKind, version])
  @@index([documentKind, isActive])
  @@map("contract_templates")
}

// --- Legal Documents (proyección materializada del ciclo contractual) ---

enum LegalDocumentStatus {
  DRAFT
  APPROVED
  SENT_TO_SIGNATURE
  SIGNED
  DECLINED
  EXPIRED
  CANCELED
}

model LegalDocument {
  id                         String              @id @default(cuid())
  operationId                String
  propertyCode               String
  documentKind               String
  templateVersion            String?
  status                     LegalDocumentStatus @default(DRAFT)
  contractInput              Json?
  /// Cláusulas adicionales libres escritas por el agente desde el editor
  /// WYSIWYG (TipTap JSON con subset controlado: paragraph, bold, italic,
  /// fontSize S/M/L, bulletList, orderedList). Opcional y editable solo
  /// mientras el documento esté en DRAFT.
  additionalClausesDoc       Json?
  additionalClausesUpdatedAt DateTime?
  /// Detalles añadidos por el comercial dentro de secciones específicas
  /// del contrato (ej. ampliar el apartado INMUEBLE con datos registrales
  /// extra o anejos). Estructurado: array de { id, sectionId, type,
  /// contentDoc (subset TipTap), updatedAtIso? }. sectionId queda validado
  /// contra el catálogo de cada documentKind en la API. Editable solo
  /// mientras el documento esté en DRAFT.
  sectionAddendums           Json?
  sectionAddendumsUpdatedAt  DateTime?
  cloudinaryUrl              String?
  signedDocumentUrl          String?
  auditTrailUrl              String?
  approvedAt                 DateTime?
  approvedByUserId           String?
  completedAt                DateTime?
  signatureRequestId         String?             @unique
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  signatureRequest SignatureRequest?    @relation(fields: [signatureRequestId], references: [id], onDelete: SetNull)
  parties          LegalDocumentParty[]

  @@unique([operationId, documentKind])
  @@index([propertyCode])
  @@index([status])
  @@map("legal_documents")
}

model LegalDocumentParty {
  id                String    @id @default(cuid())
  legalDocumentId   String
  role              String
  fullName          String
  nifNie            String?
  email             String?
  phone             String?
  address           String?
  inmovilla_cod_cli String?
  hasSigned         Boolean   @default(false)
  signedAt          DateTime?
  reminderDay       Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  legalDocument LegalDocument @relation(fields: [legalDocumentId], references: [id], onDelete: Cascade)

  @@unique([legalDocumentId, email])
  @@index([legalDocumentId, hasSigned])
  @@map("legal_document_parties")
}

model SignatureRequest {
  id                    String                 @id @default(cuid())
  signaturitSignatureId String?                @unique
  signaturitDocumentId  String?
  operationId           String
  propertyCode          String
  documentKind          String
  templateVersion       String?
  cloudinaryUrl         String
  signingUrl            String?
  status                SignatureRequestStatus @default(SENT)
  signerName            String
  signerEmail           String
  signerPhone           String?
  sentAt                DateTime               @default(now())
  openedAt              DateTime?
  signedAt              DateTime?
  completedAt           DateTime?
  declinedAt            DateTime?
  expiredAt             DateTime?
  slaDeadlineDays       Int                    @default(5)
  slaDeadline           DateTime
  lastReminderDay       Int                    @default(0)
  escalatedAt           DateTime?
  signedDocumentUrl     String?
  auditTrailUrl         String?
  documentHash          String?
  signingToken          String?                @unique
  signerIp              String?
  signerUserAgent       String?
  consentText           String?
  signedDocumentHash    String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  legalDocument LegalDocument?

  otps SignatureOtp[]

  @@index([status, slaDeadline])
  @@index([operationId])
  @@map("signature_requests")
}

model SignatureOtp {
  id                 String    @id @default(cuid())
  signatureRequestId String
  phone              String
  codeHash           String
  verified           Boolean   @default(false)
  attempts           Int       @default(0)
  expiresAt          DateTime
  verifiedAt         DateTime?
  createdAt          DateTime  @default(now())

  signatureRequest SignatureRequest @relation(fields: [signatureRequestId], references: [id], onDelete: Cascade)

  @@index([signatureRequestId, verified])
  @@map("signature_otps")
}

