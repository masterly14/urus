  language       String
  status         String
  category       String?
  components     Json
  raw            Json
  syncedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([name, language])
  @@index([status])
  @@map("whatsapp_templates")
}

// ── M5: Rematch masivo por demanda ──────────────────────────────────────────

enum RematchRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

model RematchRun {
  id                String           @id @default(cuid())
  status            RematchRunStatus @default(RUNNING)
  demandIdsList     Json             @default("[]")
  totalDemands      Int
  totalBatches      Int
  currentBatch      Int              @default(0)
  demandsProcessed  Int              @default(0)
  matchesEmitted    Int              @default(0)
  matchesSkipped    Int              @default(0)
  errorMessage      String?
  triggeredByUserId String
  startedAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([status, startedAt])
  @@map("rematch_runs")
}

// ---------------------------------------------------------------------------
// Core de Inteligencia de Mercado (Market*)
//
// Capa de datos del Core descrito en docs/core-sistema-mercado.md y
// docs/core-sistema-mercado-plan-implementacion.md. Construye un inventario
// canónico de mercado a partir de fuentes externas, con identidad estable,
// versionado de cambios y snapshots de lectura. Independiente del Event Store
// principal: usa MarketEvent como event log dedicado del dominio.
// ---------------------------------------------------------------------------

enum MarketSource {
  source_a
  source_b
  source_c
  source_d
  unknown
}

enum MarketOperation {
  sale
  rent
}

enum MarketHousingType {
  flat
  house
  countryhouse
  duplex
  penthouse
  studio
  loft
  garage
  office
  premises
  land
  building
  storage
  warehouse
  room
}

enum MarketListingStatus {
  active
  inactive
  removed
  blocked
  unknown
}

enum MarketCaptacionStage {
  NEW
  PROSPECT_CREATING
  PROSPECT_CREATED
  ENCARGO_ATTACHED
  READY_FOR_PROPERTY
  PROPERTY_CREATING
  PROPERTY_CREATED
  FAILED
}

enum CrawlRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  PARTIAL
}

enum RawListingStatus {
  CAPTURED
  NORMALIZED
  REJECTED
  STALE
}

enum MarketEventType {
  MARKET_LISTING_CREATED
  MARKET_LISTING_UPDATED
  MARKET_LISTING_PRICE_CHANGED
  MARKET_LISTING_STATUS_CHANGED
  MARKET_LISTING_REMOVED
  MARKET_LISTING_REAPPEARED
  MARKET_PROPERTY_MERGED
  MARKET_PROPERTY_SPLIT
  MARKET_PROPERTY_REVIEW_REQUIRED
  MARKET_SNAPSHOT_REFRESHED
}

enum MarketCircuitBreakerStatus {
  CLOSED
  OPEN
  HALF_OPEN
}

enum MarketZoneValidationPriority {
  P1_active_inventory
  P2_historical_inventory
  P3_no_stock
}

enum MarketZoneCoverageStatus {
  validated
  known_unprofiled
  redirected
  out_of_scope
  deprecated
}

enum MarketZonePricingProfileStatus {
  ready
  heuristic
  not_ready
  redirected
  not_applicable
  deprecated
}

enum MarketZoneMacroArea {
  Centro
  Norte
  Sur
  Este
  Oeste
  Sierra
  Periurbano
}

enum MarketZoneMarketSegment {
  popular
  medio
  medio_alto
  premium
}

enum MarketZoneQualityProfile {
  basico
  medio
  alto
}

enum MarketZoneDemandLevel {
  baja
  media
  alta
}

enum MarketZoneLiquidityLevel {
  lenta
  media
  rapida
}

enum MarketZoneBuildingAgeProfile {
  nuevo
  mixto
  antiguo
}

enum MarketZoneComparableRadiusMode {
  intra_zone_only
  zone_plus_mirrors
  dynamic
}

enum MarketZoneSourceQuality {
  alta
  media
  baja
}

enum MarketZoneRelationType {
  comparable
  not_comparable
}

enum MarketZoneRelationStrength {
  strong
  medium
  weak
}

enum MarketZoneAliasType {
  canonical
  inmovilla_name
  raw_variant
  redirect_legacy
}

enum DemographicDensityBucket {
  baja
  media
  alta
  muy_alta
}

enum ZonePoiType {
  transport
  school
  health
  retail
  green
}

enum ZoneTravelMode {
  driving
  transit
  walking
}

enum ZoneTravelDestinationType {
  city_center
  transport
  school
  health
  retail
  green
}

model MarketZoneProfile {
  id                 String                         @id @default(cuid())
  catalogVersion     String                         @default("v1.1")
  priorityRank       Int
  validationPriority MarketZoneValidationPriority
  keyLoca            Int
  keyZona            Int                            @unique
  zonaInmovilla      String
  suggestedZoneCode  String                         @unique

  coverageStatus       MarketZoneCoverageStatus
  pricingProfileStatus MarketZonePricingProfileStatus
  zoneNameCanonical    String
  macroArea            MarketZoneMacroArea?

  marketSegment      MarketZoneMarketSegment?
  qualityProfile     MarketZoneQualityProfile?
  demandLevel        MarketZoneDemandLevel?
  liquidityLevel     MarketZoneLiquidityLevel?
  priceBandM2Min     Float?
  priceBandM2Max     Float?
  dominantHousingTypes String[]                    @default([])
  buildingAgeProfile MarketZoneBuildingAgeProfile?
  amenitiesProfile   String[]                       @default([])

  comparableRadiusMode           MarketZoneComparableRadiusMode?
  comparableWithZoneCodes        String[]           @default([])
  notComparableWithZoneCodes     String[]           @default([])

  sourceQuality    MarketZoneSourceQuality?
  ownerTeam        String                           @default("")
  validatedBy      String?
  validatedAt      DateTime?
  isActive         Boolean                          @default(true)
  redirectToZoneCode String?

  inventoryCountActive      Int                      @default(0)
  inventoryCountHistorical  Int                      @default(0)
  avgPriceM2Active          Float?
  medianPriceM2Active       Float?
  avgPriceM2Historical      Float?
  medianPriceM2Historical   Float?
  unitSizeMinActive         Float?
  unitSizeMaxActive         Float?
  dominantTiposDetected     String[]                @default([])
  sampleActivePropertyCodes String[]                @default([])
  sampleHistoricalPropertyCodes String[]            @default([])
  rawZoneVariants           String[]                @default([])
  notes                     String                  @default("")

  importedAt DateTime                               @default(now())
  updatedAt  DateTime                               @updatedAt

  outgoingRelations MarketZoneRelation[]            @relation("MarketZoneRelationsFrom")
  incomingRelations MarketZoneRelation[]            @relation("MarketZoneRelationsTo")
  aliases           MarketZoneAlias[]

  @@index([catalogVersion, keyLoca])
  @@index([coverageStatus, pricingProfileStatus])
  @@index([isActive, pricingProfileStatus])
  @@index([validationPriority, priorityRank])
  @@index([zoneNameCanonical])
  @@map("market_zone_profiles")
}

model MarketZoneRelation {
  id                 String                    @id @default(cuid())
  catalogVersion     String                    @default("v1.1")
  fromZoneCode       String
  toZoneCode         String
  relationType       MarketZoneRelationType
  strength           MarketZoneRelationStrength @default(medium)
  reason             String?
  isSymmetric        Boolean                   @default(false)
  asymmetryReason    String?
  conflictResolvedBy String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  fromZone MarketZoneProfile @relation("MarketZoneRelationsFrom", fields: [fromZoneCode], references: [suggestedZoneCode], onDelete: Cascade)
  toZone   MarketZoneProfile @relation("MarketZoneRelationsTo", fields: [toZoneCode], references: [suggestedZoneCode], onDelete: Cascade)

  @@unique([fromZoneCode, toZoneCode, relationType])
  @@index([fromZoneCode, relationType])
  @@index([toZoneCode, relationType])
  @@index([catalogVersion])
  @@map("market_zone_relations")
}

model MarketZoneAlias {
  id              String             @id @default(cuid())
  keyLoca         Int
  keyZona         Int
  zoneCode        String
  aliasRaw        String
  aliasNormalized String
  aliasType       MarketZoneAliasType
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  zone MarketZoneProfile @relation(fields: [zoneCode], references: [suggestedZoneCode], onDelete: Cascade)

  @@unique([zoneCode, aliasNormalized, aliasType])
  @@index([keyLoca, keyZona])
  @@index([aliasNormalized])
  @@map("market_zone_aliases")
}

/// Semilla de rastreo: combinación (source, operation, city[, zone]) con URL de
/// listado del portal y cadencia de revisita. El scheduler selecciona seeds
/// vencidos (lastRunAt + cadenceMinutes < now) para encolar MarketCrawlRun.
model MarketSeed {
  id             String          @id @default(cuid())
  source         MarketSource
  operation      MarketOperation
  city           String
  zone           String?
  url            String
  active         Boolean         @default(true)
  priority       Int             @default(100)
  cadenceMinutes Int             @default(120)
  lastRunAt      DateTime?
  lastCursor     String?
  notes          String          @default("")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  crawlRuns MarketCrawlRun[]

  @@unique([source, operation, city, zone, url])
  @@index([active, lastRunAt])
  @@index([source, active])
  @@map("market_seeds")
}

/// Ciclo de captura para un seed concreto. Un MarketCrawlRun procesa N páginas
/// con presupuesto de tiempo/requests y materializa MarketRawListing.
model MarketCrawlRun {
  id             String         @id @default(cuid())
  seedId         String
  source         MarketSource
  status         CrawlRunStatus @default(PENDING)
  startedAt      DateTime       @default(now())
  finishedAt     DateTime?
  pagesScanned   Int            @default(0)
  itemsCaptured  Int            @default(0)
  itemsRejected  Int            @default(0)
  blockedCount   Int            @default(0)
  errorCode      String?
  errorMessage   String?
  budgetMs       Int            @default(60000)
  budgetRequests Int            @default(50)
  cursorIn       String?
  cursorOut      String?
  correlationId  String

  seed     MarketSeed         @relation(fields: [seedId], references: [id], onDelete: Cascade)
  rawItems MarketRawListing[]

  @@index([seedId, startedAt])
  @@index([status, startedAt])
  @@index([correlationId])
  @@map("market_crawl_runs")
}

/// Captura bruta indexada por contenido. La fuente de verdad técnica para
/// reproceso: si cambian las reglas de normalización, se reprocesa desde aquí
/// sin volver a raspar el portal. Retención configurable (ver decisiones.md).
model MarketRawListing {
  id              String           @id @default(cuid())
  source          MarketSource
  externalId      String?
  canonicalUrl    String
  crawlRunId      String
  httpStatus      Int?
  contentHash     String
  payload         Json
  status          RawListingStatus @default(CAPTURED)
  rejectionReason String?
  capturedAt      DateTime         @default(now())

  crawlRun MarketCrawlRun @relation(fields: [crawlRunId], references: [id], onDelete: Cascade)

  @@unique([source, contentHash])
  @@index([crawlRunId])
  @@index([source, externalId])
  @@index([status, capturedAt])
  @@map("market_raw_listings")
}

/// Listing canónico (proyección normalizada de un anuncio en un portal).
/// Identidad estable por (source, externalId). Puede vincularse a una
/// MarketProperty cuando la resolución cross-portal supera el umbral.
model MarketListing {
  id           String              @id @default(cuid())
  source       MarketSource
  externalId   String
  canonicalUrl String
  operation    MarketOperation
  housingType  MarketHousingType
  status       MarketListingStatus @default(active)

  price         Float?
  currency      String @default("EUR")
  pricePerMeter Float?

  builtArea Float?
  rooms     Int?
  bathrooms Int?
  floor     String?

  city          String
  zone          String?
  addressApprox String?
  lat           Float?
  lng           Float?
  geohash       String?

  advertiserType      String?
  advertiserName      String?
  phones              String[]  @default([])
  advertiserId        String?
  assignedComercialId String?
  assignedAt          DateTime?
  assignedByUserId    String?

  mainImageUrl String?
  imageUrls    String[] @default([])

  description         String?
  listingReference    String?
  cadastralRef        String?
  detailFetchedAt     DateTime?
  detailFetchAttempts Int       @default(0)

  qualityScore Float    @default(0)
  qualityFlags String[] @default([])

  captacionStage           MarketCaptacionStage @default(NEW)
  inmovillaProspectRef     String?
  captacionProspectSentByUserId String?
  captacionProspectSentAt  DateTime?
  inmovillaPropertyCodOfer Int?
  captacionLastError       String?
  /// Razon explicita del comercial cuando descarta la oportunidad (move a FAILED
  /// desde el kanban). Distinto de `captacionLastError` que captura fallos
  /// tecnicos del pipeline.
  captacionFailureReason   String?
  captacionUpdatedAt       DateTime             @default(now())

  propertyId   String?
  firstSeenAt  DateTime  @default(now())
  lastSeenAt   DateTime  @default(now())
  lastChangeAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property          MarketProperty?        @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  advertiser        MarketAdvertiser?      @relation(fields: [advertiserId], references: [id], onDelete: SetNull)
  assignedComercial Comercial?             @relation("MarketListingAssignedComercial", fields: [assignedComercialId], references: [id], onDelete: SetNull)
  assignedByUser    User?                  @relation("MarketListingAssignedByUser", fields: [assignedByUserId], references: [id], onDelete: SetNull)
  prospectSentByUser User?                 @relation("MarketListingProspectSentByUser", fields: [captacionProspectSentByUserId], references: [id], onDelete: SetNull)
  versions          MarketListingVersion[]
  images            MarketListingImage[]

  @@unique([source, externalId])
  @@index([city, zone])
  @@index([operation, housingType])
  @@index([status, lastSeenAt])
  @@index([price])
  @@index([propertyId])
  @@index([advertiserId])
  @@index([captacionStage, lastSeenAt])
  @@index([inmovillaProspectRef])
  @@index([inmovillaPropertyCodOfer])
  @@index([assignedComercialId, lastSeenAt])
  @@index([assignedByUserId])
  @@index([captacionProspectSentByUserId, captacionProspectSentAt])
  @@index([geohash])
  @@index([listingReference])
  @@index([cadastralRef])
  @@map("market_listings")
}

model MarketAdvertiser {
  id                 String   @id @default(cuid())
  phoneCanonical     String?
  displayName        String?
  advertiserType     String?
  inmovillaContactId String?
  listingsCount      Int      @default(0)
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  listings MarketListing[]

  @@index([advertiserType, lastSeenAt])
  @@index([displayName])
  @@map("market_advertisers")
}

/// Histórico de cambios por listing. Una fila por cambio detectado por el
/// diff engine. Retención por política (ver decisiones.md, sección 7.3).
model MarketListingVersion {
  id            String   @id @default(cuid())
  listingId     String
  changedFields String[]
  before        Json
  after         Json
  capturedAt    DateTime @default(now())

  listing MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, capturedAt])
  @@map("market_listing_versions")
}

/// Cache propio de imagenes para MarketListing (paralelo a
/// StatefoxComparableImage). Permite servir URLs Cloudinary estables a
/// pricing/microsites sin depender del CDN del portal (que caduca/firma).
/// Ver docs/statefox-deprecation.md para el plan de portado.
model MarketListingImage {
  id                  String    @id @default(cuid())
  listingId           String
  imageIndex          Int
  originalImageUrl    String
  originalImageSha256 String?
  cloudinaryPublicId  String?
  cloudinarySecureUrl String?
  width               Int?
  height              Int?
  bytes               Int?
  format              String?
  /// PENDING | IMPORTING | IMPORTED | FAILED | BLOCKED | CAPTCHA |
  /// LISTING_REMOVED | NO_IMAGES_FOUND. String porque el set crece con
  /// la chain anti-bot.
  status              String    @default("PENDING")
  errorReason         String?
  attempts            Int       @default(0)
  lastAttemptAt       DateTime?
  importedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  listing MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, imageIndex])
  @@index([listingId, status])
  @@index([status, updatedAt])
  @@index([originalImageSha256])
  @@map("market_listing_images")
}

/// Inmueble subyacente probable. Agrupa MarketListing del mismo bien físico
/// publicado en múltiples portales. La resolución se hace por fingerprint
/// determinístico + similitud (ver lib/market/identity.ts).
model MarketProperty {
  id                      String   @id @default(cuid())
  city                    String
  zone                    String?
  geohash                 String?
  fingerprint             String   @unique
  representativeListingId String?
  listingsCount           Int      @default(0)
  firstSeenAt             DateTime @default(now())
  lastSeenAt              DateTime @default(now())
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  listings MarketListing[]

  @@index([city, zone])
  @@index([geohash])
  @@map("market_properties")
}

/// Event log dedicado del Core. Independiente del Event Store principal para
/// no inflarlo con el alto volumen de eventos de mercado. La idempotencia se
/// garantiza con (type, fingerprint) único por evento.
model MarketEvent {
  id               String          @id @default(cuid())
  type             MarketEventType
  listingId        String?
  propertyId       String?
  source           MarketSource?
  payload          Json
  fingerprint      String
  correlationId    String
  occurredAt       DateTime        @default(now())
  /// Resolucion para eventos accionables (MARKET_PROPERTY_REVIEW_REQUIRED).
  /// NULL = pendiente. Cuando un admin actua desde
  /// /platform/market/identity/review se rellena con timestamp + userId +
  /// accion (merge | split | ignore).
  resolvedAt       DateTime?
  resolvedBy       String?
  resolutionAction String?

  @@unique([type, fingerprint])
  @@index([type, occurredAt])
  @@index([listingId, occurredAt])
  @@index([propertyId, occurredAt])
  @@index([correlationId])
  @@map("market_events")
}

/// Vista agregada por (city, housingType, operation) para consumidores
/// (búsqueda, pricing, captación). Recalculada periódicamente por
/// MARKET_REFRESH_SNAPSHOT.
model MarketSnapshotIndex {
  id          String            @id @default(cuid())
  city        String
  housingType MarketHousingType
  operation   MarketOperation
  freshAt     DateTime          @default(now())
  totalActive Int               @default(0)
  priceMin    Float?
  priceMax    Float?
  priceMedian Float?
  ppmMedian   Float?

  @@unique([city, housingType, operation])
  @@index([freshAt])
  @@map("market_snapshot_index")
}

/// Estado del circuit breaker por fuente. Se abre cuando hay tasa alta de
/// bloqueos/errores y degrada la chain anti-bot a modo conservador.
/// Alerta guardada por usuario sobre el inventario de mercado.
/// Una alerta es una "busqueda persistente": filtros + canales de entrega +
/// frecuencia. El cron `run-rules` evalua periodicamente y entrega cada match
/// nuevo (no presente en MarketAlertDelivery con misma dedupeKey).
model MarketSavedAlert {
  id              String    @id @default(cuid())
  /// userId del owner. Solo el owner ve/edita la alerta.
  userId          String
  name            String
  /// Filtros JSON con la misma forma que /api/market/properties/search:
  /// { city, sources, operation, advertiserType, hasPhone, priceMin, priceMax,
  ///   areaMin, areaMax, roomsMin, polygon }.
  filters         Json
  /// Canales de entrega: in_app | whatsapp.
  channels        String[]
  /// Frecuencia de evaluacion: realtime | hourly | daily.
  frequency       String    @default("hourly")
  active          Boolean   @default(true)
  lastEvaluatedAt DateTime?
  lastDeliveredAt DateTime?
  deliveryCount   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  deliveries MarketAlertDelivery[]

  @@index([userId, active])
  @@index([active, lastEvaluatedAt])
  @@map("market_saved_alerts")
}

/// Registro idempotente de cada entrega. dedupeKey unique evita reenviar el
/// mismo match en una segunda evaluacion.
model MarketAlertDelivery {
  id          String   @id @default(cuid())
  alertId     String
  listingId   String
  channel     String
  deliveredAt DateTime @default(now())
  /// Hash determinista: sha256(alertId|listingId|eventType|fechaUTC).
  dedupeKey   String   @unique
  payload     Json?

  alert MarketSavedAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId, deliveredAt])
  @@index([listingId, deliveredAt])
  @@map("market_alert_deliveries")
}

model MarketCircuitBreaker {
  source       MarketSource               @id
  status       MarketCircuitBreakerStatus @default(CLOSED)
  failureCount Int                        @default(0)
  openedAt     DateTime?
  halfOpenAt   DateTime?
  closedAt     DateTime?
  updatedAt    DateTime                   @updatedAt

  @@map("market_circuit_breakers")
}
