enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum ProjectionName {
  PROPERTIES_CURRENT
  DEMANDS_CURRENT
}

enum SignatureRequestStatus {
  SENT
  OPENED
  SIGNED
  COMPLETED
  DECLINED
  EXPIRED
  CANCELED
  ERROR
}

enum MicrositeSelectionStatus {
  PENDING_VALIDATION
  APPROVED
  REJECTED
  EXPIRED
}

enum MicrositeSelectionDecision {
  ME_INTERESA
  NO_ME_ENCAJA
}

enum StatefoxPortalSource {
  idealista
  fotocasa
  pisoscom
  habitaclia
  unknown
}

enum StatefoxImageCacheStatus {
  PENDING
  IMPORTED
  FAILED
  BLOCKED
  CAPTCHA
  LISTING_REMOVED
  NO_IMAGES_FOUND
}

enum PortalWarmSessionStatus {
  ACTIVE
  EXPIRED
  EXHAUSTED
  INVALIDATED
}

model Event {
  id            String        @id @default(cuid())
  position      BigInt        @unique @default(autoincrement())
  type          EventType
  aggregateType AggregateType
  aggregateId   String
  version       Int?
  payload       Json
  metadata      Json?
  correlationId String?
  causationId   String?
  occurredAt    DateTime      @default(now())
  createdAt     DateTime      @default(now())
  jobs          JobQueue[]

  @@index([aggregateType, aggregateId, position])
  @@index([type, position])
  @@index([occurredAt])
  @@index([type, aggregateType, aggregateId])
  @@map("events")
}

model JobQueue {
  id             String    @id @default(cuid())
  type           JobType
  status         JobStatus @default(PENDING)
  payload        Json
  priority       Int       @default(100)
  attempts       Int       @default(0)
  maxAttempts    Int       @default(5)
  availableAt    DateTime  @default(now())
  lockedAt       DateTime?
  lockedBy       String?
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  lastError      String?
  idempotencyKey String?   @unique
  sourceEventId  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sourceEvent    Event?    @relation(fields: [sourceEventId], references: [id])

  @@index([status, availableAt, priority])
  @@index([type, status])
  @@index([sourceEventId])
  @@map("job_queue")
}

model ProjectionCheckpoint {
  projectionName    ProjectionName @id
  lastEventId       String?
  lastEventPosition BigInt?
  lastProcessedAt   DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("projections_checkpoint")
}

/// H6: key-value genérico para checkpoints de ingestion y otros estados
/// operacionales que no merecen tabla dedicada.
model KvStore {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("kv_store")
}

model PropertySnapshot {
  codigo             String   @id
  ref                String
  refCatastral       String?
  titulo             String   @default("")
  tipoOfer           String   @default("")
  precio             Float    @default(0)
  metrosConstruidos  Float    @default(0)
  habitaciones       Int      @default(0)
  banyos             Int      @default(0)
  ciudad             String   @default("")
  zona               String   @default("")
  estado             String   @default("")
  nodisponible       Boolean  @default(false)
  prospecto          Boolean  @default(false)
  fechaAlta          String   @default("")
  fechaActualizacion String   @default("")
  numFotos           Int      @default(0)
  agente             String   @default("")
  /// URL absoluta de la foto principal (thumbnail). Derivada de numagencia+cod_ofer+fotoletra.
  mainPhotoUrl       String?
  raw                Json     @default("{}")
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("property_snapshots")
}

model DemandSnapshot {
  codigo             String   @id
  ref                String   @default("")
  nombre             String   @default("")
  estadoId           String   @default("")
  estadoNombre       String   @default("")
  presupuestoMin     Float    @default(0)
  presupuestoMax     Float    @default(0)
  habitacionesMin    Int      @default(0)
  tipos              String   @default("")
  zonas              String   @default("")
  fechaActualizacion String   @default("")
  agente             String   @default("")
  telefono           String   @default("")
  raw                Json     @default("{}")
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("demand_snapshots")
}

model PropertyCurrent {
  codigo                     String    @id
  ref                        String    @default("")
  refCatastral               String?
  titulo                     String    @default("")
  tipoOfer                   String    @default("")
  precio                     Float     @default(0)
  metrosConstruidos          Float     @default(0)
  habitaciones               Int       @default(0)
  banyos                     Int       @default(0)
  ciudad                     String    @default("")
  zona                       String    @default("")
  estado                     String    @default("")
  nodisponible               Boolean   @default(false)
  prospecto                  Boolean   @default(false)
  fechaAlta                  String    @default("")
  fechaActualizacion         String    @default("")
  numFotos                   Int       @default(0)
  agente                     String    @default("")
  /// ID interno del comercial gestor (resuelto desde keyagente de Inmovilla)
  comercialId                String?
  /// URL absoluta de la foto principal. Se llenará en FASE 2 desde el worker
  /// que cachea la foto en Cloudinary (source: `lafoto` de la API legacy o
  /// URL construida con numagencia+cod_ofer+fotoletra de la REST v1).
  mainPhotoUrl               String?
  /// URL pública del anuncio en el portal inmobiliario principal donde está
  /// publicado (prioridad Idealista). Se llenará en FASE 2 desde el worker
  /// que consume `GET /propiedades/?extrainfo&cod_ofer=` → `publishinfo[idealista].publication_url`.
  portalUrl                  String?
  /// Nombre canónico del portal al que apunta `portalUrl` (ej. "idealista", "pisos.com", "fotocasa").
  portalName                 String?
  /// Última vez que el worker de extrainfo sincronizó portalUrl/portalName (null si nunca).
  portalSyncedAt             DateTime?
  /// Datos de propietario capturados desde Nota de Encargo cuando la propiedad aún no existía en Inmovilla.
  propietarioNombre          String?
  propietarioDni             String?
  propietarioPhone           String?
  propietarioDomicilioFiscal String?
  propietarioRegisteredAt    DateTime?
  /// Sesión de Nota de Encargo desde la que se copiaron los datos del propietario.
  notaEncargoSessionId       String?
  lastEventId                String
  lastEventPosition          BigInt
  lastEventAt                DateTime
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@index([estado])
  @@index([ciudad, zona])
  @@index([comercialId])
  @@index([refCatastral])
  @@index([lastEventPosition])
  @@index([portalSyncedAt])
  @@index([notaEncargoSessionId])
  @@map("properties_current")
}

model PricingReport {
  propertyCode              String   @id
  analyzedAt                DateTime
  sourceTrigger             String   @default("manual")
  semaforo                  String   @default("sin_datos")
  gapPorcentaje             Float    @default(0)
  totalComparables          Int      @default(0)
  input                     Json
  stats                     Json
  comparables               Json
  recommendation            Json?
  recommendationError       String?
  trend                     Json?
  queryMeta                 Json
  lastAnalysisEventId       String?
  lastRecommendationEventId String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([analyzedAt])
  @@index([sourceTrigger, analyzedAt])
  @@index([semaforo, analyzedAt])
  @@map("pricing_reports")
}

model StatefoxComparableImage {
  id                  String                   @id @default(cuid())
  source              StatefoxPortalSource
  statefoxId          String
  portalUrl           String
  imageIndex          Int
  originalImageUrl    String?
  originalImageSha256 String?
  cloudinaryPublicId  String?
  cloudinarySecureUrl String?
  width               Int?
  height              Int?
  bytes               Int?
  format              String?
  status              StatefoxImageCacheStatus @default(PENDING)
  errorReason         String?
  attempts            Int                      @default(0)
  lastAttemptAt       DateTime?
  importedAt          DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@unique([source, statefoxId, imageIndex])
  @@index([statefoxId, status])
  @@index([source, status, updatedAt])
  @@index([originalImageSha256])
  @@map("statefox_comparable_images")
}

model PortalWarmSession {
  id            String                  @id @default(cuid())
  source        StatefoxPortalSource
  cookieHeader  String
  userAgent     String
  proxySession  String?
  status        PortalWarmSessionStatus @default(ACTIVE)
  requestCount  Int                     @default(0)
  maxRequests   Int                     @default(40)
  expiresAt     DateTime
  lastUsedAt    DateTime?
  warmedAt      DateTime                @default(now())
  invalidatedAt DateTime?
  invalidReason String?

  @@index([source, status, expiresAt])
  @@map("portal_warm_sessions")
}

/// Informe estratégico IA del mercado agregado (M7 — Smart Pricing).
///
/// Se genera on-demand desde `/platform/pricing/mercado` a través de LangGraph
/// sobre los datos ya agregados por `/api/pricing/mercado` para una ciudad
/// (o todas si `ciudad = "Todas"`). Persiste el snapshot de entrada usado y el
/// informe estructurado devuelto por el LLM. Cada generación emite un evento
/// `MARKET_INFORME_GENERADO` en el Event Store con `aggregateType = MARKET`.
model MarketReport {
  id            String   @id @default(cuid())
  /// Ciudad del alcance del informe. "Todas" cuando no se filtró por ciudad.
  ciudad        String
  /// Usuario que disparó la generación (AppSession.userId).
  generatedBy   String
  /// Modelo LLM usado (p. ej. "gpt-5.4-mini").
  model         String
  /// Snapshot de los datos agregados de mercado usados como input del LLM
  /// (zones + competitors recortados a lo enviado al prompt).
  inputSnapshot Json
  /// Informe estructurado (MarketReportSchema de Zod) devuelto por el graph.
  report        Json
  /// Tokens consumidos si el proveedor los reporta; null si no.
  tokensUsed    Int?
  /// ID del evento `MARKET_INFORME_GENERADO` emitido al persistir.
  lastEventId   String?
  generatedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ciudad, generatedAt])
  @@index([generatedBy, generatedAt])
  @@map("market_reports")
}

model DemandCurrent {
  codigo             String     @id
  ref                String     @default("")
  nombre             String     @default("")
  estadoId           String     @default("")
  estadoNombre       String     @default("")
  presupuestoMin     Float      @default(0)
  presupuestoMax     Float      @default(0)
  habitacionesMin    Int        @default(0)
  tipos              String     @default("")
  zonas              String     @default("")
  fechaActualizacion String     @default("")
  agente             String     @default("")
  /// ID interno del comercial gestor (resuelto desde agente de Inmovilla)
  comercialId        String?
  lastEventId        String
  lastEventPosition  BigInt
  lastEventAt        DateTime
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  /// * Teléfono del contacto/comprador si la ingesta lo expone (E.164 o dígitos).
  telefono           String     @default("")
  /// Estado del pipeline interno. Independiente de Inmovilla; se actualiza
  /// a través de los eventos del event-store (ver docs/lead-status-pipeline.md).
  leadStatus         LeadStatus @default(NUEVO)
  /// Superficie mínima solicitada (m²). Materializado vía DEMANDA_ACTUALIZADA
  /// con variables extraídas por NLU. Nullable porque la API de Inmovilla
  /// no lo devuelve en el snapshot de demandas.
  metrosMin          Int?
  /// Superficie máxima solicitada (m²). Materializado vía DEMANDA_ACTUALIZADA
  /// con variables extraídas por NLU.
  metrosMax          Int?
  /// Tipo de operación ("venta" | "alquiler"). Reservado para extracción NLU futura.
  /// Hoy siempre null hasta que el grafo NLU lo incluya en variables.
  tipoOperacion      String?

  @@index([estadoId])
  @@index([zonas])
  @@index([comercialId])
  @@index([lastEventPosition])
  @@index([leadStatus])
  @@map("demands_current")
}

model IngestionCycleMetric {
  id                String   @id @default(cuid())
  cycleId           String   @unique
  worker            String
  mode              String
  success           Boolean
  startedAt         DateTime
  finishedAt        DateTime
  durationMs        Int
  itemsRead         Int      @default(0)
  itemsFetched      Int      @default(0)
  itemsFailed       Int      @default(0)
  snapshotSize      Int      @default(0)
  eventsEmitted     Int      @default(0)
  diffCreated       Int      @default(0)
  diffModified      Int      @default(0)
  diffStatusChanged Int      @default(0)
  diffUnchanged     Int      @default(0)
  errorMessage      String?
  errorCode         String?
  phases            Json     @default("{}")
  createdAt         DateTime @default(now())

  @@index([worker, startedAt])
  @@index([success, startedAt])
  @@map("ingestion_cycle_metrics")
}

model ObservabilityLog {
  id            String   @id @default(cuid())
