model MicrositeSelection {
  id                     String                       @id @default(cuid())
  /// * Token público para el comprador: /seleccion/{token}
  token                  String                       @unique
  status                 MicrositeSelectionStatus     @default(PENDING_VALIDATION)
  demandId               String
  demandNombre           String                       @default("")
  comercialId            String                       @default("system")
  /// * Query params enviados a Statefox (/properties).
  statefoxQuery          Json
  /// * Filtros aplicados en memoria (precio/metros/keywords...).
  resultFilters          Json
  /// * Lista curada para renderizar el microsite.
  properties             Json
  stockCount             Int                          @default(0)
  sourceEventId          String?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  expiresAt              DateTime?
  firstViewedAt          DateTime?
  lastViewedAt           DateTime?
  viewCount              Int                          @default(0)
  /// * Token opaco para el comercial: /validar-seleccion/{validationToken}
  validationToken        String                       @unique
  /// * Teléfono del comprador resuelto al crear la selección (envío WA).
