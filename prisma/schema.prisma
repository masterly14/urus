// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AggregateType {
  PROPERTY
  LEAD
  DEMAND
  MATCH
  SLA
  SYSTEM
}

enum EventType {
  PROPIEDAD_CREADA
  PROPIEDAD_MODIFICADA
  ESTADO_CAMBIADO
  DEMANDA_CREADA
  DEMANDA_MODIFICADA
  DEMANDA_ESTADO_CAMBIADO
  LEAD_INGESTADO
  SLA_INICIADO
  DEMANDA_ACTUALIZADA
  MATCH_GENERADO
}

enum JobType {
  PROCESS_EVENT
  UPDATE_PROPERTY_PROJECTION
  UPDATE_DEMAND_PROJECTION
  WRITE_TO_INMOVILLA
}

enum JobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum ProjectionName {
  PROPERTIES_CURRENT
  DEMANDS_CURRENT
}

model Event {
  id            String        @id @default(cuid())
  position      BigInt        @unique @default(autoincrement())
  type          EventType
  aggregateType AggregateType
  aggregateId   String
  version       Int?
  payload       Json
  metadata      Json?
  correlationId String?
  causationId   String?
  occurredAt    DateTime      @default(now())
  createdAt     DateTime      @default(now())

  jobs          JobQueue[]

  @@index([aggregateType, aggregateId, position])
  @@index([type, position])
  @@index([occurredAt])
  @@map("events")
}

model JobQueue {
  id             String     @id @default(cuid())
  type           JobType
  status         JobStatus  @default(PENDING)
  payload        Json
  priority       Int        @default(100)
  attempts       Int        @default(0)
  maxAttempts    Int        @default(5)
  availableAt    DateTime   @default(now())
  lockedAt       DateTime?
  lockedBy       String?
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  lastError      String?
  idempotencyKey String?    @unique
  sourceEventId  String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  sourceEvent    Event?     @relation(fields: [sourceEventId], references: [id], onDelete: SetNull)

  @@index([status, availableAt, priority])
  @@index([type, status])
  @@index([sourceEventId])
  @@map("job_queue")
}

model ProjectionCheckpoint {
  projectionName     ProjectionName @id
  lastEventId        String?
  lastEventPosition  BigInt?
  lastProcessedAt    DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@map("projections_checkpoint")
}

model PropertySnapshot {
  codigo             String   @id
  ref                String
  titulo             String   @default("")
  tipoOfer           String   @default("")
  precio             Float    @default(0)
  metrosConstruidos  Float    @default(0)
  habitaciones       Int      @default(0)
  banyos             Int      @default(0)
  ciudad             String   @default("")
  zona               String   @default("")
  estado             String   @default("")
  fechaAlta          String   @default("")
  fechaActualizacion String   @default("")
  numFotos           Int      @default(0)
  agente             String   @default("")
  raw                Json     @default("{}")
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("property_snapshots")
}

model DemandSnapshot {
  codigo             String   @id
  ref                String   @default("")
  nombre             String   @default("")
  estadoId           String   @default("")
  estadoNombre       String   @default("")
  presupuestoMin     Float    @default(0)
  presupuestoMax     Float    @default(0)
  habitacionesMin    Int      @default(0)
  tipos              String   @default("")
  zonas              String   @default("")
  fechaActualizacion String   @default("")
  agente             String   @default("")
  raw                Json     @default("{}")
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("demand_snapshots")
}

model User {
  id String @id @default(cuid())
}