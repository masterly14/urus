  statusCode      Int?
  requestId       String?
  correlationId   String?
  workerId        String?
  workerName      String?
  jobId           String?
  jobType         String?
  eventId         String?
  eventType       String?
  route           String?
  method          String?
  errorMessage    String?
  errorCode       String?
  context         Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([scope, startedAt])
  @@index([source, startedAt])
  @@index([name, startedAt])
  @@index([operation, startedAt])
  @@index([success, startedAt])
  @@index([requestId])
  @@index([correlationId])
  @@index([workerId, startedAt])
  @@index([jobId, startedAt])
  @@index([eventId, startedAt])
  @@map("execution_metrics")
}

// ---------------------------------------------------------------------------
// Visit Scheduling (M4 — rediseño)
// ---------------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Lead Status — pipeline interno (no depende de Inmovilla)
// ---------------------------------------------------------------------------

enum LeadStatus {
  NUEVO // Demanda recibida de Inmovilla; sin contacto aún
  CONTACTADO // Primer contacto realizado vía WhatsApp
  EN_SELECCION // Comprador interactuando con microsites o propiedades
  VISITA_PENDIENTE // Comprador expresó ME_INTERESA; coordinando visita
  VISITA_CONFIRMADA // Visita agendada en calendario (comprador aceptó slot)
  VISITA_REALIZADA // Visita completada; datos recopilados
  EN_NEGOCIACION // Post-visita: contrato o propuesta en proceso
  EN_FIRMA // Firma digital enviada / en trámite
  CERRADO // Operación cerrada exitosamente
  PERDIDO // Lead perdido (escalado sin resolución / cancelado)
}

enum VisitSessionState {
  INITIATED
  FETCHING_SLOTS
  SLOTS_PROPOSED_TO_COMMERCIAL
  COMMERCIAL_ACCEPTED_SLOT
  SLOT_PROPOSED_TO_BUYER
  BUYER_ACCEPTED
  BUYER_REJECTED
  ASKING_BUYER_PREFERENCE
  FETCHING_SPECIFIC_SLOT
  SPECIFIC_SLOT_TO_COMMERCIAL
  COLLECTING_VISITOR_DATA
  VISIT_CONFIRMED
  VISIT_COMPLETED
  VISIT_CANCELLED
  VISIT_RESCHEDULED
  ESCALATED_MANUAL
}

enum VisitWorkItemStatus {
  INCOMPLETE
  PENDING_SCHEDULE
  SCHEDULED
  COMPLETED
  DECIDED_GREEN
  DECIDED_YELLOW
  DECIDED_RED
  CANCELLED
}

model VisitSchedulingSession {
  id                  String            @id @default(cuid())
  demandId            String
  propertyCode        String
  comercialId         String
  buyerWaId           String
  comercialWaId       String
  state               VisitSessionState @default(INITIATED)
  currentRound        Int               @default(0)
  maxRounds           Int               @default(3)
  confirmedSlotStart  DateTime?
  confirmedSlotEnd    DateTime?
  visitorName         String?
  visitorPhone        String?
  visitorCount        Int?
  calendarEventId     String?
  calendarLink        String?
  escalationReason    String?
  lastProposedSlots   Json?
  lastCommercialMsgId String?
  lastBuyerMsgId      String?
  buyerPreferredDate  String?
  currentStepDeadline DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  completedAt         DateTime?

  @@index([demandId])
  @@index([buyerWaId, state])
  @@index([comercialWaId, state])
  @@index([propertyCode, state])
  @@map("visit_scheduling_sessions")
}

model VisitWorkItem {
  id                  String              @id @default(cuid())
  demandId            String
  selectionId         String              @default("")
  propertyId          String
  propertySource      String
  comercialId         String
  buyerName           String              @default("")
  buyerPhone          String              @default("")
  propertySnapshot    Json
  contactSnapshot     Json
  nluSummary          String              @default("")
  status              VisitWorkItemStatus @default(PENDING_SCHEDULE)
  scheduledSessionId  String?
  missingContactPhone Boolean             @default(false)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([demandId, selectionId, propertyId])
  @@index([comercialId, status])
  @@index([demandId])
  @@index([selectionId])
  @@index([propertyId])
