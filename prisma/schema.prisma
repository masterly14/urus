  source        String
  operation     String
  level         String
  message       String
  requestId     String?
  correlationId String?
  workerId      String?
  workerName    String?
  jobId         String?
  jobType       String?
  eventId       String?
  eventType     String?
  route         String?
  method        String?
  statusCode    Int?
  durationMs    Int?
  errorMessage  String?
  errorStack    String?
  context       Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([scope, createdAt])
  @@index([source, createdAt])
  @@index([level, createdAt])
  @@index([operation, createdAt])
  @@index([requestId])
  @@index([correlationId])
  @@index([workerId, createdAt])
  @@index([jobId, createdAt])
  @@index([eventId, createdAt])
  @@map("observability_logs")
}

model ExecutionMetric {
  id              String   @id @default(cuid())
  scope           String
  source          String
  name            String
  operation       String
  success         Boolean
  startedAt       DateTime
  finishedAt      DateTime
  durationMs      Int
